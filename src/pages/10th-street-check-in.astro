---
import BaseLayout from "../layouts/BaseLayout.astro";
import Ribbon from "../components/Ribbon.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (path: string) => `${base}${path}`;

// Same three destinations as the /facilities 10th Street section. Kept in sync
// by hand — if these change there, change them here too.
const GUIDELINES = "https://docs.google.com/document/d/1RFGhuBCfTaJu7H9k6fkn8T7z_Qch0iOkI7fRHVVGftM/edit?tab=t.zggakcezu7da";
const WAIVER = "https://docs.google.com/forms/d/e/1FAIpQLSf1DZCi5av126Bf1tOIFiZaiDv-Gjy7dDEePpT9YFo4dWNKPA/viewform";
const CHECKIN = "https://script.google.com/a/macros/piedmontmakers.org/s/AKfycbyvQwtTkmCk_P9k3dd3CmrjXh-zDBHaTt93uSC2swZIZbzhNFx8PNKuXhBnufjAUqLheA/exec";

// Order follows the visitor flow: read the guidelines, sign the waiver once,
// then check in on every arrival. Notes guide first-timers and regulars alike.
const actions = [
  { label: "Practice Field Guidelines", href: GUIDELINES, note: "Read these first." },
  { label: "Sign the waiver", href: WAIVER, note: "Once, before your first visit." },
  { label: "Check-in form", href: CHECKIN, note: "Every time you arrive." },
];

const MAPS = "https://www.google.com/maps/search/?api=1&query=3100+East+10th+Street+Oakland+CA";
---

<BaseLayout
  title="10th Street Check-In — Piedmont Makers"
  description="Check in to the Piedmont Makers 10th Street practice field: practice field guidelines, the visitor waiver, and the check-in form."
>
  <section class="mx-auto max-w-7xl px-6 pt-12 md:pt-16 pb-20">
    <div class="max-w-xl">
      <Ribbon color="cyan">10th Street</Ribbon>
      <h1 class="mt-6 font-display font-bold text-pm-ink text-4xl md:text-5xl tracking-tight leading-[1.02]">
        Check in to the practice field.
      </h1>
      <p class="mt-4 text-lg text-pm-ink/75 leading-relaxed">
        New here? Read the guidelines and sign the waiver once. Every time you arrive, fill out the check-in form.
      </p>

      <div class="mt-8 space-y-4">
        {actions.map((a) => (
          <a
            href={a.href}
            target="_blank"
            rel="noopener"
            class="group flex items-center justify-between gap-4 rounded-2xl border-[3px] border-pm-ink bg-pm-paper px-6 py-5 hover:bg-white transition-colors"
          >
            <span class="min-w-0">
              <span class="block font-display font-bold text-xl md:text-2xl tracking-tight text-pm-ink leading-tight">{a.label}</span>
              <span class="mt-1 block text-sm text-pm-ink/65">{a.note}</span>
            </span>
            <span aria-hidden="true" class="shrink-0 font-display text-2xl text-pm-red group-hover:translate-x-1 transition-transform">→</span>
          </a>
        ))}
      </div>

      <p class="mt-10 text-sm text-pm-ink/65 leading-relaxed">
        <span class="font-display font-semibold text-pm-ink">3100 East 10th Street, Oakland, CA</span><br />
        <a href={MAPS} target="_blank" rel="noopener" class="font-display font-semibold underline underline-offset-4 decoration-pm-red hover:text-pm-red">Open in Maps →</a>
        <span class="mx-2 text-pm-ink/30">·</span>
        <a href={link("/facilities#tenth-street")} class="font-display font-semibold underline underline-offset-4 decoration-pm-red hover:text-pm-red">More about the facility →</a>
      </p>
    </div>
  </section>
</BaseLayout>
