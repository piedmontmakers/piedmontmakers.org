---
import BaseLayout from "../layouts/BaseLayout.astro";
import Ribbon from "../components/Ribbon.astro";
import PhotoCard from "../components/PhotoCard.astro";
import Scribble from "../components/Scribble.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (path: string) => `${base}${path}`;

// Mailchimp audience details extracted from existing newsletter campaign links.
// Hidden honeypot input name must be `b_{u}_{id}` for bot protection.
const MAILCHIMP_ACTION = "https://piedmontmakers.us3.list-manage.com/subscribe/post?u=edc89d8dd41a4ea6ee9352d9a&id=83b9d5d7df";
const MAILCHIMP_HONEYPOT_NAME = "b_edc89d8dd41a4ea6ee9352d9a_83b9d5d7df";
const NEWSLETTER_URL = MAILCHIMP_ACTION;

const programs = [
  {
    name: "Robotics",
    headline: "From LEGO bricks to 120-pound competition robots",
    ages: "Ages 5–18 · K through high school",
    blurb: "Four levels by age and intensity. Teams meet weekly, compete regionally, and (for the older ones) build their own robots from scratch.",
    color: "red" as const,
    href: "/robotics",
    caption: "Photo: FRC drive team at championship",
    levels: [
      { name: "FLL Explore", ages: "K–3rd" },
      { name: "FLL Challenge", ages: "4th–8th" },
      { name: "FTC", ages: "7th–12th" },
      { name: "FRC", ages: "high school" },
    ],
  },
  {
    name: "School Maker Faire",
    headline: "Our biggest event of the year",
    ages: "All ages · Each May",
    blurb: "K-12 students show what they made all year — Rube Goldberg machines, robots, embroidered patches, soldered circuits, 3D-printed everything. Free, open to the public.",
    color: "cyan" as const,
    href: "/school-maker-faire",
    caption: "Photo: 2025 Maker Faire main floor",
  },
  {
    name: "Popup Maker Spaces",
    headline: "Hands-on workshops, sporadically scheduled",
    ages: "All ages · Dates vary",
    blurb: "A few Saturdays a year we open a space and load it with tools — soldering irons, sewing machines, 3D printers, cardboard, hot glue, whatever&apos;s on hand. Show up and make.",
    color: "purple" as const,
    href: "/community",
    caption: "Photo: kids at a popup maker space session",
  },
];
---

<BaseLayout title="Piedmont Makers — STEAM, robotics & maker culture for Piedmont kids">
  <!-- HERO: photo-led, parent-facing -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-pm-cream"></div>

    <div class="mx-auto max-w-7xl px-6 pt-10 md:pt-16 pb-20 md:pb-28">
      <div class="grid md:grid-cols-12 gap-8 md:gap-12 items-center">
        <div class="md:col-span-6 md:order-1">
          <Ribbon color="red">Welcome</Ribbon>
          <h1 class="mt-6 font-display font-bold tracking-tight text-pm-ink text-5xl md:text-6xl lg:text-7xl leading-[0.95]">
            Where Piedmont kids learn to make
            <span class="relative inline-block">
              <span class="relative z-10">almost anything.</span>
              <Scribble variant="underline" color="red" class="absolute -bottom-2 left-0 w-full h-3" />
            </span>
          </h1>
          <p class="mt-7 max-w-xl text-lg md:text-xl text-pm-ink/75 leading-relaxed">
            Robotics teams, an after-school engineering lab, a yearly school maker faire, and popup maker spaces all over town. Free or low-cost. Run by parents and volunteers right here in your neighborhood.
          </p>
          <div class="mt-10 flex flex-wrap items-center gap-3">
            <a href={link("/robotics")} class="ribbon bg-pm-red text-white text-base hover:bg-pm-red-deep transition-colors">Sign your kid up</a>
            <a href="#newsletter" class="inline-flex items-center gap-2 rounded-full border-2 border-pm-ink px-5 py-2.5 font-display font-semibold text-pm-ink hover:bg-pm-ink hover:text-pm-cream transition-colors">
              Get our newsletter
            </a>
            <span class="font-marker text-2xl text-pm-purple ml-2 hidden md:inline-block">since 2014!</span>
          </div>
        </div>

        <div class="md:col-span-6 md:order-2 relative">
          <div class="relative h-[460px] md:h-[540px]">
            <div class="absolute top-0 right-0 w-[78%] aspect-[4/3] rounded-3xl bg-pm-cyan overflow-hidden shadow-[var(--shadow-card)] tilt-right">
              <div class="w-full h-full flex items-end p-6">
                <div>
                  <span class="font-display text-[10px] uppercase tracking-[0.18em] text-white/75 block">Photo</span>
                  <span class="font-body text-sm text-white/95">FRC Team 8627 drive practice</span>
                </div>
              </div>
            </div>
            <div class="absolute bottom-0 left-0 w-[58%] aspect-[3/4] rounded-3xl bg-pm-red overflow-hidden shadow-[var(--shadow-card)] tilt-left-md">
              <div class="w-full h-full flex items-end p-6">
                <div>
                  <span class="font-display text-[10px] uppercase tracking-[0.18em] text-white/75 block">Photo</span>
                  <span class="font-body text-sm text-white/95">Maker Faire 2026, the big build</span>
                </div>
              </div>
            </div>
            <div class="absolute top-12 left-0 md:-left-4 w-[34%] aspect-square rounded-2xl bg-pm-cream-2 overflow-hidden shadow-[var(--shadow-card)] tilt-right tape-top-left">
              <div class="w-full h-full flex items-end p-3">
                <span class="font-marker text-base text-pm-ink/85">Makey says hi!</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROGRAMS: 3 top-level cards -->
  <section class="relative">
    <div class="mx-auto max-w-7xl px-6 pt-20 pb-12">
      <div class="flex flex-wrap items-end justify-between gap-6 mb-10">
        <div>
          <Ribbon color="cyan">Programs</Ribbon>
          <h2 class="mt-5 font-display font-bold text-4xl md:text-5xl tracking-tight">
            Three ways to get your kid making.
          </h2>
        </div>
        <a href={link("/robotics")} class="font-display font-semibold text-pm-ink hover:text-pm-red underline-offset-4 hover:underline whitespace-nowrap">
          See all programs →
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-x-6 gap-y-10">
        {programs.map((p, i) => (
          <a href={link(p.href)} class="group block">
            <PhotoCard
              caption={p.caption}
              color={p.color}
              tilt={i === 1 ? "right" : i === 0 ? "left" : "none"}
              tape={i === 2 ? "right" : "none"}
              aspect="landscape"
            />
            <div class="mt-4 px-1">
              <Ribbon color={p.color}>{p.name}</Ribbon>
              <p class="mt-3 font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55">{p.ages}</p>
              <h3 class="mt-2 font-display font-bold text-2xl tracking-tight leading-tight">{p.headline}</h3>
              <p class="mt-3 text-pm-ink/80 leading-relaxed">{p.blurb}</p>
              {p.levels && (
                <ul class="mt-4 space-y-1 text-sm text-pm-ink/75">
                  {p.levels.map((lvl) => (
                    <li class="flex items-baseline gap-2">
                      <span class="font-display font-semibold text-pm-ink">{lvl.name}</span>
                      <span class="text-pm-ink/55">· {lvl.ages}</span>
                    </li>
                  ))}
                </ul>
              )}
              <p class="mt-4 font-display font-semibold text-pm-ink group-hover:text-pm-red transition-colors">
                Learn more →
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- THIS YEAR -->
  <section class="mt-16 bg-pm-cream-2/70 text-pm-ink">
    <div class="mx-auto max-w-7xl px-6 py-16 md:py-20">
      <div class="grid md:grid-cols-12 gap-10 items-start">
        <div class="md:col-span-4">
          <Ribbon color="red">This year</Ribbon>
          <h2 class="mt-5 font-display font-bold text-4xl md:text-5xl tracking-tight leading-[1.02]">
            What&apos;s coming up at Piedmont Makers.
          </h2>
          <p class="mt-5 text-pm-ink/75 leading-relaxed max-w-sm">
            Specific dates land in <a href="#newsletter" class="font-display font-semibold text-pm-ink underline underline-offset-4 hover:text-pm-red">the newsletter</a> first.
          </p>
        </div>
        <div class="md:col-span-8 grid sm:grid-cols-2 gap-6">
          <a href={link("/school-maker-faire")} class="group block bg-pm-paper p-7 border-[3px] border-pm-ink hover:bg-white transition-colors">
            <span class="font-display text-xs uppercase tracking-[0.18em] text-pm-red">Sat May 17 · 2026</span>
            <h3 class="mt-3 font-display font-bold text-2xl md:text-[1.7rem] tracking-tight leading-tight">12th Annual School Maker Faire</h3>
            <p class="mt-3 text-pm-ink/75 leading-relaxed">K-12 students show what they made all year. Free, open to the public, all-day at the Veterans&apos; Building.</p>
            <p class="mt-5 font-display font-semibold text-pm-ink group-hover:text-pm-red transition-colors">Details →</p>
          </a>
          <a href={link("/community")} class="group block bg-pm-paper p-7 border-[3px] border-pm-ink hover:bg-white transition-colors">
            <span class="font-display text-xs uppercase tracking-[0.18em] text-pm-purple">Date TBD · Sign up to hear first</span>
            <h3 class="mt-3 font-display font-bold text-2xl md:text-[1.7rem] tracking-tight leading-tight">Next popup maker space</h3>
            <p class="mt-3 text-pm-ink/75 leading-relaxed">A Saturday of soldering, sewing, 3D printing, and whatever else is on the table that day. Subscribe to the newsletter for the next date.</p>
            <p class="mt-5 font-display font-semibold text-pm-ink group-hover:text-pm-red transition-colors">About popup spaces →</p>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- STAY IN THE LOOP — full-bleed cyan newsletter band -->
  <section id="newsletter" class="bg-pm-cyan text-white scroll-mt-20">
    <div class="mx-auto max-w-7xl px-6 py-20 md:py-24">
      <div class="grid md:grid-cols-12 gap-10 items-center">
        <div class="md:col-span-7">
          <div class="inline-flex items-center gap-3">
            <span class="font-marker text-2xl text-white/90">psst —</span>
            <Ribbon color="ink">Newsletter</Ribbon>
          </div>
          <h2 class="mt-5 font-display font-bold text-4xl md:text-5xl tracking-tight leading-[1.02]">
            The newsletter is how we actually talk to parents.
          </h2>
          <p class="mt-5 max-w-xl text-lg text-white/90 leading-relaxed">
            One or two emails a month. Robotics sign-up windows, popup maker space dates, Maker Faire prep, board recaps, occasional photos of finished projects. No spam. Unsubscribe anytime.
          </p>
        </div>
        <div class="md:col-span-5">
          <form
            action={MAILCHIMP_ACTION}
            method="post"
            target="_blank"
            novalidate
            class="bg-pm-paper text-pm-ink border-[3px] border-pm-ink p-7 shadow-[var(--shadow-card)]"
          >
            <p class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55">Mailchimp · free · unsubscribe anytime</p>
            <label for="newsletter-email" class="block mt-3 font-display font-bold text-2xl md:text-[1.7rem] tracking-tight leading-tight">
              Get the newsletter
            </label>
            <div class="mt-4 flex flex-col sm:flex-row gap-2">
              <input
                type="email"
                name="EMAIL"
                id="newsletter-email"
                required
                placeholder="you@example.com"
                autocomplete="email"
                class="flex-1 min-w-0 border-2 border-pm-ink/30 focus:border-pm-ink focus:outline-none px-4 py-3 font-body bg-white text-pm-ink placeholder:text-pm-ink/40"
              />
              <button
                type="submit"
                name="subscribe"
                class="ribbon bg-pm-red text-white text-base hover:bg-pm-red-deep transition-colors cursor-pointer whitespace-nowrap"
              >
                Subscribe →
              </button>
            </div>
            <p class="mt-3 text-sm text-pm-ink/65 leading-relaxed">
              We&apos;ll open Mailchimp in a new tab to confirm. No spam — promise.
            </p>
            <!-- Honeypot field: real visitors can't see this, bots fill it in and get rejected. -->
            <div aria-hidden="true" style="position: absolute; left: -5000px;">
              <input type="text" name={MAILCHIMP_HONEYPOT_NAME} tabindex="-1" value="" />
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY WE MAKE — Makey -->
  <section class="bg-pm-purple text-white">
    <div class="mx-auto max-w-7xl px-6 py-20 md:py-24 grid md:grid-cols-12 gap-10 items-center">
      <div class="md:col-span-5 flex items-center justify-center md:justify-start">
        <img src={`${base}/img/brand/makey.png`} alt="Makey, the Piedmont Makers mascot" class="w-72 md:w-80 h-auto" />
      </div>
      <div class="md:col-span-7">
        <p class="font-marker text-3xl text-pm-cream/90">why we make</p>
        <h2 class="mt-2 font-display font-bold text-4xl md:text-5xl tracking-tight leading-[1.04]">
          Because every kid in Piedmont should get to build something they&apos;re proud of.
        </h2>
        <p class="mt-6 text-lg text-white/85 leading-relaxed max-w-2xl">
          We&apos;re a 501(c)(3) run by parents and volunteers. We don&apos;t charge admission to most of what we do. We give $25,000+ in STEAM grants to local teachers every year. We run robotics teams, a community engineering lab, a school maker faire that&apos;s now in its 12th year, and popup maker spaces around town.
        </p>
        <p class="mt-4 text-lg text-white/85 leading-relaxed max-w-2xl">
          The reason it all works is the same reason most good community things work: a lot of people show up, regularly, and pitch in.
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a href={link("/about")} class="ribbon bg-pm-cream text-pm-ink text-base hover:bg-white transition-colors">Meet the board</a>
          <a href={link("/community")} class="inline-flex items-center gap-2 rounded-full border-2 border-white px-5 py-2.5 font-display font-semibold text-white hover:bg-white hover:text-pm-purple transition-colors">
            Volunteer with us
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW TO HELP -->
  <section class="mx-auto max-w-7xl px-6 py-20 md:py-24">
    <div class="text-center max-w-3xl mx-auto">
      <Ribbon color="red">How to help</Ribbon>
      <h2 class="mt-5 font-display font-bold text-4xl md:text-5xl tracking-tight">
        Three ways to keep this going.
      </h2>
      <p class="mt-4 text-pm-ink/75 text-lg leading-relaxed">
        We&apos;re an entirely volunteer-run nonprofit. Any of these helps a lot.
      </p>
    </div>
    <div class="mt-12 grid md:grid-cols-3 gap-6">
      <a href="https://donate.piedmontmakers.org" class="block rounded-3xl bg-pm-ink text-pm-cream p-8 hover:bg-pm-ink-soft transition-colors group">
        <span class="font-marker text-2xl text-pm-red">tax-deductible!</span>
        <h3 class="mt-2 font-display font-bold text-3xl tracking-tight">Donate</h3>
        <p class="mt-3 text-pm-cream/80 leading-relaxed">Direct to programs. Square-processed. EIN 81-2725831.</p>
        <p class="mt-6 font-display font-semibold text-pm-cream group-hover:text-pm-red transition-colors">Go to donate.piedmontmakers.org →</p>
      </a>
      <a href={link("/community")} class="block rounded-3xl bg-pm-cyan text-white p-8 hover:bg-pm-cyan-deep transition-colors group">
        <span class="font-marker text-2xl text-pm-cream">we need you!</span>
        <h3 class="mt-2 font-display font-bold text-3xl tracking-tight">Volunteer</h3>
        <p class="mt-3 text-white/85 leading-relaxed">Coach a team, mentor at Maker Faire, help with the next popup. A few hours a month makes a real difference.</p>
        <p class="mt-6 font-display font-semibold group-hover:text-pm-ink transition-colors">See open roles →</p>
      </a>
      <a href="https://www.bonfire.com/piedmont-makers-t-shirt/" class="block rounded-3xl bg-pm-cream-2 text-pm-ink p-8 hover:bg-pm-cream transition-colors group">
        <span class="font-marker text-2xl text-pm-purple">on Bonfire</span>
        <h3 class="mt-2 font-display font-bold text-3xl tracking-tight">Buy a shirt</h3>
        <p class="mt-3 text-pm-ink/75 leading-relaxed">Makey, in full color, on quality cotton. Proceeds fund the programs.</p>
        <p class="mt-6 font-display font-semibold text-pm-ink group-hover:text-pm-red transition-colors">Shop the store →</p>
      </a>
    </div>
  </section>
</BaseLayout>
