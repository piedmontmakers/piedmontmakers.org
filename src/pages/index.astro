---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Piedmont Makers">
  <section class="py-16">
    <p class="text-sm uppercase tracking-widest text-neutral-500">Coming soon</p>
    <h1 class="mt-4 font-display text-5xl md:text-6xl font-semibold tracking-tight text-neutral-900">
      A new home for Piedmont Makers.
    </h1>
    <p class="mt-6 max-w-2xl text-lg text-neutral-700">
      We&apos;re rebuilding piedmontmakers.org. The full site is on its way — in the meantime,
      our existing site is still live at <a href="https://www.piedmontmakers.org" class="underline">www.piedmontmakers.org</a>.
    </p>
    <div class="mt-10 flex flex-wrap gap-4">
      <a
        href="https://donate.piedmontmakers.org"
        class="rounded-full bg-neutral-900 px-6 py-3 text-white hover:bg-neutral-700"
      >
        Donate
      </a>
      <a
        href="https://www.bonfire.com/piedmont-makers-t-shirt/"
        class="rounded-full border border-neutral-300 px-6 py-3 text-neutral-900 hover:bg-neutral-50"
      >
        Shop t-shirts
      </a>
    </div>
  </section>
</BaseLayout>
