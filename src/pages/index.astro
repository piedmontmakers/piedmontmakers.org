---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Ribbon from "../components/Ribbon.astro";
import PhotoCard from "../components/PhotoCard.astro";
import Scribble from "../components/Scribble.astro";
import VoicesBand from "../components/VoicesBand.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (path: string) => `${base}${path}`;

const latestPosts = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const formatDate = (d: Date) =>
  d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });

const asset = (path: string) => `${base}${path.startsWith("/") ? path : `/${path}`}`;
const blogThumbFallback = "/img/brand/makey.png";

// Placeholder voices — swap in real quotes from kids, volunteer coaches, and
// partner teachers when collected. The structure is the point: the community
// is the hero, not the org.
const voices = [
  {
    quote: "We made a robot that picked up four cones in a row. I helped program the arm.",
    name: "Anya",
    role: "5th grade · FLL Challenge",
    accentColor: "red" as const,
  },
  {
    quote: "I started coaching because my kid was on the team. I stayed because the other kids are great.",
    name: "Marco",
    role: "FTC parent coach",
    accentColor: "cyan" as const,
  },
  {
    quote: "My students built a working circuit on a t-shirt. Piedmont Makers paid for the LEDs.",
    name: "Ms. Chen",
    role: "Beach Elementary · 4th grade",
    accentColor: "purple" as const,
  },
];

// Mailchimp audience details extracted from the unsubscribe link in the
// January 2026 newsletter campaign. Hidden honeypot input name must be
// `b_{u}_{id}` so Mailchimp's bot filter recognizes it.
const MAILCHIMP_ACTION = "https://piedmontmakers.us3.list-manage.com/subscribe/post?u=edc89d8dd41a4ea6ee9352d9a&id=83b9d5d7df";
const MAILCHIMP_HONEYPOT_NAME = "b_edc89d8dd41a4ea6ee9352d9a_83b9d5d7df";

const roboticsLevels = [
  {
    name: "FIRST LEGO League Explore",
    ages: "K–3rd",
    blurb: "Gentle intro to robotics with LEGO Education kits.",
    color: "red" as const,
    src: "/img/robotics/fll-explore.jpg",
    caption: "Younger kids building LEGO Technic together",
    alt: "Four young boys in purple Piedmont Makers shirts sitting on the floor of a gym building LEGO Technic structures.",
  },
  {
    name: "FIRST LEGO League Challenge",
    ages: "4th–8th",
    blurb: "Build LEGO robots, run autonomous missions, present an innovation project.",
    color: "cyan" as const,
    src: "/img/robotics/fll-challenge.jpg",
    caption: "A Challenge team at the SUBMERGED season tournament",
    alt: "Five girls in maroon Piedmont Makers shirts working at an FLL Challenge competition table with a LEGO ocean-themed game board.",
  },
  {
    name: "FIRST Tech Challenge",
    ages: "7th–12th",
    blurb: "Custom metal robots, Java programming, regional competitions.",
    color: "purple" as const,
    src: "/img/robotics/ftc.jpg",
    caption: "A playoff match at the league tournament",
    alt: "FTC playoff match in progress at John Morrison Gymnasium — referees, team members at the alliance stations, and robots on the competition field.",
  },
  {
    name: "FIRST Robotics Competition",
    ages: "high school",
    blurb: "120-pound competition robots, full build season, real engineering.",
    color: "ink" as const,
    src: "/img/robotics/frc.jpg",
    caption: "Highlander Robotics 8033 around the robot at championship",
    alt: "Members of Highlander Robotics Team 8033 around their robot at a championship pit, with sponsor banners visible.",
  },
];

const events = [
  {
    name: "School Maker Faire",
    when: "Sat May 17 · 2026",
    headline: "Our biggest event of the year",
    blurb: "K-12 students show what they made all year — Rube Goldberg machines, robots, embroidered patches, soldered circuits, 3D-printed everything. Free, open to the public.",
    color: "red" as const,
    href: "/programs/maker-faire",
    src: "/img/programs/maker-faire.jpg",
    caption: "Kids at the Maker Faire LEGO play table",
    alt: "Children and parents gathered around a large outdoor LEGO play table at the Piedmont School Maker Faire.",
    tilt: "left" as const,
    tape: "none" as const,
  },
  {
    name: "Popup Maker Spaces",
    when: "Sporadic Saturdays · Sign up to hear first",
    headline: "Hands-on workshops, free to drop in",
    blurb: "A few times a year we open a space and load it with tools — soldering irons, sewing machines, 3D printers, cardboard, hot glue, whatever&apos;s on hand. Show up and make.",
    color: "cyan" as const,
    href: "/programs/popup-maker-spaces",
    src: "/img/programs/popup.jpg",
    caption: "Kids and parents making at a popup maker space",
    alt: "Children and parents at long tables making craft projects with paper, markers, and cardboard inside a community hall.",
    tilt: "right" as const,
    tape: "left" as const,
  },
  {
    name: "Build Like a Girl",
    when: "Multiple sessions · Watch the newsletter",
    headline: "Young girls excited about robotics",
    blurb: "Mentored by the older female students from our FTC and FRC teams. A confidence-and-tools program: hands-on robotics taught by girls who&apos;ve been doing it for years.",
    color: "purple" as const,
    href: "/programs/build-like-a-girl",
    src: "/img/programs/build-like-a-girl.jpg",
    caption: "Older FRC students demoing a robot to a crowd of younger girls",
    alt: "High school students in purple Piedmont Makers sweatshirts demonstrating a robot to a crowd of young girls.",
    tilt: "left" as const,
    tape: "right" as const,
  },
];
---

<BaseLayout title="Piedmont Makers — STEAM, robotics & maker culture for East Bay kids">
  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-pm-cream"></div>

    <div class="mx-auto max-w-7xl px-6 pt-10 md:pt-16 pb-20 md:pb-28">
      <div class="grid md:grid-cols-12 gap-8 md:gap-12 items-center">
        <div class="md:col-span-6 md:order-1">
          <Ribbon color="red">Welcome</Ribbon>
          <h1 class="mt-6 font-display font-bold tracking-tight text-pm-ink text-5xl md:text-6xl lg:text-7xl leading-[0.95]">
            Where East Bay kids learn to make
            <span class="relative inline-block">
              <span class="relative z-10">almost anything.</span>
              <Scribble variant="underline" color="red" class="absolute -bottom-2 left-0 w-full h-3" />
            </span>
          </h1>
          <p class="mt-7 max-w-xl text-lg md:text-xl text-pm-ink/75 leading-relaxed">
            We run the <strong>largest community-based youth robotics league in the United States</strong>, an after-school engineering lab, a yearly school maker faire, and popup maker spaces across the East Bay. Free or low-cost. Run by parents and volunteers.
          </p>
          <div class="mt-10 flex flex-wrap items-center gap-3">
            <a href={link("/robotics")} class="ribbon bg-pm-red text-white text-base hover:bg-pm-red-deep transition-colors">Sign your kid up</a>
            <a href="#newsletter" class="inline-flex items-center gap-2 rounded-full border-2 border-pm-ink px-5 py-2.5 font-display font-semibold text-pm-ink hover:bg-pm-ink hover:text-pm-cream transition-colors">
              Get our newsletter
            </a>
            <span class="font-marker text-2xl text-pm-purple ml-2 hidden md:inline-block">since 2014!</span>
          </div>
        </div>

        <div class="md:col-span-6 md:order-2 relative">
          <div class="relative h-[460px] md:h-[540px]">
            <div class="absolute top-0 right-0 w-[78%] aspect-[4/3] rounded-3xl overflow-hidden border-[3px] border-pm-ink shadow-[var(--shadow-card)] tilt-right">
              <img
                src={asset("/img/programs/build-like-a-girl.jpg")}
                alt="High school students from FRC Team 8033 in purple Piedmont Makers sweatshirts demonstrating a robot to a crowd of younger girls."
                class="w-full h-full object-cover"
                loading="eager"
              />
            </div>
            <div class="absolute bottom-0 left-0 w-[58%] aspect-[3/4] rounded-3xl overflow-hidden border-[3px] border-pm-ink shadow-[var(--shadow-card)] tilt-left-md">
              <img
                src={asset("/img/programs/maker-faire.jpg")}
                alt="Kids and parents gathered around a large outdoor LEGO play table at the Piedmont School Maker Faire."
                class="w-full h-full object-cover"
                loading="eager"
              />
            </div>
            <div class="absolute top-12 left-0 md:-left-4 w-[40%] aspect-square rounded-2xl overflow-hidden border-[3px] border-pm-ink shadow-[var(--shadow-card)] tilt-right">
              <img
                src={asset("/img/programs/parade.jpg")}
                alt="The giant red inflatable Makey rising above the 4th of July Parade — kids in purple Piedmont Makers shirts hold the banner below, red-white-and-blue balloons frame Makey on either side, and a kid in a soapbox car cruises past."
                class="w-full h-full object-cover"
                style="object-position: 52% 60%;"
                loading="eager"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS BAND — community in numbers, builds confidence -->
  <section class="bg-pm-ink text-pm-cream">
    <div class="mx-auto max-w-7xl px-6 py-10 md:py-12">
      <ul class="grid grid-cols-2 md:grid-cols-4 gap-y-8 gap-x-6 md:divide-x divide-pm-cream/15">
        <li class="text-center md:px-6">
          <p class="font-display font-bold text-3xl md:text-4xl text-pm-red leading-none">912</p>
          <p class="mt-2 text-sm text-pm-cream/80">students on robotics teams</p>
        </li>
        <li class="text-center md:px-6">
          <p class="font-display font-bold text-3xl md:text-4xl text-pm-cyan leading-none">91</p>
          <p class="mt-2 text-sm text-pm-cream/80">schools across 20 East Bay cities</p>
        </li>
        <li class="text-center md:px-6">
          <p class="font-display font-bold text-3xl md:text-4xl text-pm-purple leading-none">100+</p>
          <p class="mt-2 text-sm text-pm-cream/80">robotics teams, K through 12</p>
        </li>
        <li class="text-center md:px-6">
          <p class="font-display font-bold text-3xl md:text-4xl text-pm-cream leading-none">1,900+</p>
          <p class="mt-2 text-sm text-pm-cream/80">volunteer hours logged in 2024-25</p>
        </li>
      </ul>
    </div>
  </section>

  <!-- ROBOTICS — the flagship program, deep dive -->
  <section class="relative">
    <div class="mx-auto max-w-7xl px-6 pt-20 pb-12">
      <div class="grid md:grid-cols-12 gap-10 mb-12 items-end">
        <div class="md:col-span-7">
          <Ribbon color="red">Robotics</Ribbon>
          <h2 class="mt-5 font-display font-bold text-4xl md:text-5xl tracking-tight leading-[1.02]">
            From first LEGO bricks to championship robots.
          </h2>
          <p class="mt-5 text-lg text-pm-ink/75 leading-relaxed max-w-xl">
            Whether your kid is snapping their first LEGO brick or driving a 120-pound competition robot at the championship, we have a team that fits.
          </p>
        </div>
        <div class="md:col-span-5 md:text-right">
          <a href={link("/robotics")} class="inline-flex items-center gap-2 font-display font-semibold text-pm-ink hover:text-pm-red underline-offset-4 hover:underline">
            See the full Robotics page →
          </a>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-5 gap-y-10">
        {roboticsLevels.map((lvl, i) => (
          <a href={link("/robotics")} class="group block">
            <PhotoCard
              caption={lvl.caption}
              color={lvl.color}
              tilt={i % 2 === 0 ? "left" : "right"}
              tape={i === 1 ? "right" : "none"}
              aspect="square"
              src={lvl.src}
              alt={lvl.alt}
            />
            <div class="mt-4 px-1">
              <Ribbon color={lvl.color}>{lvl.name}</Ribbon>
              <p class="mt-3 font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55">Ages · {lvl.ages}</p>
              <p class="mt-2 text-pm-ink/80 leading-relaxed text-[0.95rem]">{lvl.blurb}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- PROGRAMS — Maker Faire, Popup Maker Spaces, Build Like a Girl -->
  <section class="relative mt-12 bg-pm-cream-2/60">
    <div class="mx-auto max-w-7xl px-6 py-20">
      <div class="grid md:grid-cols-12 gap-10 mb-12 items-end">
        <div class="md:col-span-7">
          <Ribbon color="cyan">Programs</Ribbon>
          <h2 class="mt-5 font-display font-bold text-4xl md:text-5xl tracking-tight leading-[1.02]">
            Come make something with us.
          </h2>
          <p class="mt-5 text-lg text-pm-ink/75 leading-relaxed max-w-xl">
            Open to anyone. Mostly free. Always hands-on.
          </p>
        </div>
        <div class="md:col-span-5 md:text-right space-y-2">
          <a href={link("/events")} class="inline-flex items-center gap-2 font-display font-semibold text-pm-ink hover:text-pm-red underline-offset-4 hover:underline">
            All upcoming dates →
          </a>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-x-6 gap-y-10">
        {events.map((e) => (
          <a href={link(e.href)} class="group block">
            <PhotoCard
              caption={e.caption}
              color={e.color}
              tilt={e.tilt}
              tape={e.tape}
              aspect="landscape"
              src={e.src}
              alt={e.alt}
            />
            <div class="mt-4 px-1">
              <Ribbon color={e.color}>{e.name}</Ribbon>
              <p class="mt-3 font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55">{e.when}</p>
              <h3 class="mt-2 font-display font-bold text-2xl tracking-tight leading-tight">{e.headline}</h3>
              <p class="mt-3 text-pm-ink/80 leading-relaxed">{e.blurb}</p>
              <p class="mt-4 font-display font-semibold text-pm-ink group-hover:text-pm-red transition-colors">
                Learn more →
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- VOICES BAND — community quotes -->
  <VoicesBand voices={voices} eyebrow="What kids and parents are telling us" />

  <!-- LATEST FROM THE BLOG -->
  <section class="mx-auto max-w-7xl px-6 pt-20 pb-4">
    <div class="grid md:grid-cols-12 gap-10 mb-12 items-end">
      <div class="md:col-span-7">
        <Ribbon color="ink">Blog</Ribbon>
        <h2 class="mt-5 font-display font-bold text-4xl md:text-5xl tracking-tight leading-[1.02]">
          Latest from the blog.
        </h2>
        <p class="mt-5 text-lg text-pm-ink/75 leading-relaxed max-w-xl">
          Project recaps, season updates, behind-the-scenes from board meetings. For things you have to act on, the newsletter is faster.
        </p>
      </div>
      <div class="md:col-span-5 md:text-right">
        <a href={link("/blog")} class="inline-flex items-center gap-2 font-display font-semibold text-pm-ink hover:text-pm-red underline-offset-4 hover:underline">
          All posts →
        </a>
      </div>
    </div>

    <ul class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {latestPosts.map((post) => {
        const hasHero = !!post.data.heroImage;
        const thumbSrc = asset(post.data.heroImage || blogThumbFallback);
        const thumbAlt = post.data.heroImageAlt || (hasHero ? post.data.title : "Makey, the Piedmont Makers mascot");
        return (
          <li>
            <a href={link(`/blog/${post.id}`)} class="group block bg-pm-paper border-[3px] border-pm-ink h-full hover:bg-white transition-colors">
              <div class:list={["aspect-[16/10] overflow-hidden border-b-[3px] border-pm-ink", hasHero ? "" : "bg-pm-purple flex items-center justify-center p-4"]}>
                <img
                  src={thumbSrc}
                  alt={thumbAlt}
                  class:list={["w-full h-full", hasHero ? "object-cover" : "object-contain"]}
                  loading="lazy"
                />
              </div>
              <div class="p-6">
                <p class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55">{formatDate(post.data.pubDate)}</p>
                <h3 class="mt-3 font-display font-bold text-xl md:text-2xl tracking-tight leading-tight group-hover:text-pm-red transition-colors">
                  {post.data.title}
                </h3>
                {post.data.excerpt && (
                  <p class="mt-3 text-pm-ink/75 leading-relaxed text-sm">{post.data.excerpt}</p>
                )}
                <p class="mt-5 font-display font-semibold text-pm-ink group-hover:text-pm-red transition-colors">
                  Read post →
                </p>
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  </section>

  <!-- STAY IN THE LOOP — full-bleed cyan newsletter band -->
  <section id="newsletter" class="bg-pm-cyan text-white scroll-mt-20">
    <div class="mx-auto max-w-7xl px-6 py-20 md:py-24">
      <div class="grid md:grid-cols-12 gap-10 items-center">
        <div class="md:col-span-7">
          <div class="inline-flex items-center gap-3">
            <span class="font-marker text-2xl text-white/90">psst —</span>
            <Ribbon color="ink">Newsletter</Ribbon>
          </div>
          <h2 class="mt-5 font-display font-bold text-4xl md:text-5xl tracking-tight leading-[1.02]">
            The newsletter is how we talk to parents.
          </h2>
          <p class="mt-5 max-w-xl text-lg text-white/90 leading-relaxed">
            One or two emails a month. Robotics sign-up windows, popup maker space dates, Maker Faire prep, board recaps, occasional photos of finished projects. No spam. Unsubscribe anytime.
          </p>
        </div>
        <div class="md:col-span-5">
          <form
            action={MAILCHIMP_ACTION}
            method="post"
            target="_blank"
            novalidate
            class="bg-pm-paper text-pm-ink border-[3px] border-pm-ink p-7 shadow-[var(--shadow-card)]"
          >
            <p class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55">Mailchimp · free · unsubscribe anytime</p>
            <label for="newsletter-email" class="block mt-3 font-display font-bold text-2xl md:text-[1.7rem] tracking-tight leading-tight">
              Get the newsletter
            </label>
            <div class="mt-4 flex flex-col sm:flex-row gap-2">
              <input
                type="email"
                name="EMAIL"
                id="newsletter-email"
                required
                placeholder="you@example.com"
                autocomplete="email"
                class="flex-1 min-w-0 border-2 border-pm-ink/30 focus:border-pm-ink focus:outline-none px-4 py-3 font-body bg-white text-pm-ink placeholder:text-pm-ink/40"
              />
              <button
                type="submit"
                name="subscribe"
                class="ribbon bg-pm-red text-white text-base hover:bg-pm-red-deep transition-colors cursor-pointer whitespace-nowrap"
              >
                Subscribe →
              </button>
            </div>
            <p class="mt-3 text-sm text-pm-ink/65 leading-relaxed">
              We&apos;ll open Mailchimp in a new tab to confirm. No spam — promise.
            </p>
            <div aria-hidden="true" style="position: absolute; left: -5000px;">
              <input type="text" name={MAILCHIMP_HONEYPOT_NAME} tabindex="-1" value="" />
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY WE MAKE — Makey -->
  <section class="bg-pm-purple text-white">
    <div class="mx-auto max-w-7xl px-6 py-20 md:py-24 grid md:grid-cols-12 gap-10 items-center">
      <div class="md:col-span-5 flex items-center justify-center md:justify-start">
        <img src={`${base}/img/brand/makey.png`} alt="Makey, the Piedmont Makers mascot" class="w-72 md:w-80 h-auto" />
      </div>
      <div class="md:col-span-7">
        <p class="font-marker text-3xl text-pm-cream/90">why we make</p>
        <h2 class="mt-2 font-display font-bold text-4xl md:text-5xl tracking-tight leading-[1.04]">
          When students build something with their own hands, they build something else too: belief in themselves.
        </h2>
        <p class="mt-6 text-lg text-white/85 leading-relaxed max-w-2xl">
          We&apos;re a 501(c)(3) run by parents and volunteers. We don&apos;t charge admission to most of what we do. We give $25,000+ in STEAM grants to Piedmont Unified teachers every year. We run robotics teams across the East Bay, a community engineering lab, a school maker faire that&apos;s now in its 12th year, popup maker spaces, and (new in 2025) after-school enrichment.
        </p>
        <p class="mt-4 text-lg text-white/85 leading-relaxed max-w-2xl">
          The reason it all works is the same reason most good community things work: a lot of people show up, regularly, and pitch in.
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a href={link("/about")} class="ribbon bg-pm-cream text-pm-ink text-base hover:bg-white transition-colors">Meet the board</a>
          <a href={link("/events")} class="inline-flex items-center gap-2 rounded-full border-2 border-white px-5 py-2.5 font-display font-semibold text-white hover:bg-white hover:text-pm-purple transition-colors">
            Volunteer with us
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW TO HELP -->
  <section class="mx-auto max-w-7xl px-6 py-20 md:py-24">
    <div class="text-center max-w-3xl mx-auto">
      <Ribbon color="red">How to help</Ribbon>
      <h2 class="mt-5 font-display font-bold text-4xl md:text-5xl tracking-tight">
        Three ways to keep this going.
      </h2>
      <p class="mt-4 text-pm-ink/75 text-lg leading-relaxed">
        We&apos;re an entirely volunteer-run nonprofit. Any of these helps a lot.
      </p>
    </div>
    <div class="mt-12 grid md:grid-cols-3 gap-6">
      <a href="https://donate.piedmontmakers.org" class="block rounded-3xl bg-pm-ink text-pm-cream p-8 hover:bg-pm-ink-soft transition-colors group">
        <span class="font-marker text-2xl text-pm-red">tax-deductible!</span>
        <h3 class="mt-2 font-display font-bold text-3xl tracking-tight">Donate</h3>
        <p class="mt-3 text-pm-cream/80 leading-relaxed">Direct to programs. Square-processed. EIN 47-2831568.</p>
        <p class="mt-6 font-display font-semibold text-pm-cream group-hover:text-pm-red transition-colors">Go to donate.piedmontmakers.org →</p>
      </a>
      <a href={link("/events")} class="block rounded-3xl bg-pm-cyan text-white p-8 hover:bg-pm-cyan-deep transition-colors group">
        <span class="font-marker text-2xl text-pm-cream">we need you!</span>
        <h3 class="mt-2 font-display font-bold text-3xl tracking-tight">Volunteer</h3>
        <p class="mt-3 text-white/85 leading-relaxed">We&apos;re volunteer-run from top to bottom. Coach a team, mentor at Maker Faire, help with the next popup — every event has its own signup.</p>
        <p class="mt-6 font-display font-semibold group-hover:text-pm-ink transition-colors">See upcoming events →</p>
      </a>
      <a href="https://www.bonfire.com/piedmont-makers-t-shirt/" class="block rounded-3xl bg-pm-cream-2 text-pm-ink p-8 hover:bg-pm-cream transition-colors group">
        <span class="font-marker text-2xl text-pm-purple">on Bonfire</span>
        <h3 class="mt-2 font-display font-bold text-3xl tracking-tight">Buy a shirt</h3>
        <p class="mt-3 text-pm-ink/75 leading-relaxed">Makey, in full color, on quality cotton. Proceeds fund the programs.</p>
