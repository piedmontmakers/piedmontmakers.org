---
import BaseLayout from "../layouts/BaseLayout.astro";
import Ribbon from "../components/Ribbon.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (path: string) => `${base}${path}`;

// 2026–27 board slate. Paul Morrison wears two hats (Secretary + VP FTC)
// and appears in both Officers and Robotics — that's intentional.
const board = {
  officers: [
    { name: "Kevin Clark", role: "Co-President" },
    { name: "Ben Stein", role: "Co-President" },
    { name: "Dave Ragones", role: "Treasurer (Interim)" },
    { name: "Paul Morrison", role: "Secretary" },
  ],
  robotics: [
    { name: "Paul Morrison", role: "VP, FIRST Tech Challenge" },
    { name: "Lara Oliver", role: "VP, FIRST Tech Challenge" },
    { name: "Pat Holder", role: "VP, FIRST LEGO League Challenge" },
    { name: "Shelley Rea", role: "VP, FIRST LEGO League Challenge" },
    { name: "Marta Lusky", role: "VP, FIRST LEGO League Explore" },
    { name: "David Koslow", role: "VP, FIRST LEGO League Explore" },
    { name: "Natalia Feretti", role: "VP, FIRST Robotics Competition" },
  ],
  programs: [
    { name: "Ella Grossberg", role: "VP, School Maker Faire" },
    { name: "Brian Van Osdol", role: "VP, School Maker Faire" },
    { name: "Rebecca Heywood", role: "VP, Grants" },
    { name: "Margaret Bridges", role: "VP, Grants" },
    { name: "Julie Veit", role: "VP, Operations" },
    { name: "Mallory Casperson", role: "VP, Fundraising" },
    { name: "Keren Khouri", role: "10th St Coordination" },
    { name: "Ken Khouri", role: "10th St Tech Lead" },
  ],
  atLarge: [
    { name: "Greg Wolff", role: "Master Maker" },
    { name: "Alex Seiden" },
    { name: "Larraine Seiden" },
    { name: "Joel Tornatore" },
    { name: "Dave McMurtry" },
  ],
  staff: [
    { name: "Alya Hameed", role: "FLL/FTC Program Manager" },
  ],
};

const impactStats = [
  { number: "~1,000", label: "kids on robotics teams", color: "text-pm-red" },
  { number: "90+", label: "schools across 20 East Bay cities", color: "text-pm-cyan" },
  { number: "1,900+", label: "volunteer hours logged", color: "text-pm-purple" },
  { number: "$25,694", label: "in teacher grants awarded", color: "text-pm-cream" },
];
---

<BaseLayout
  title="About Us — Piedmont Makers"
  description="Mission, vision, board roster, and contact info for Piedmont Makers, a 501(&zwnj;c)(3) nonprofit supporting STEAM education and maker culture across the East Bay."
>
  <!-- Hero -->
  <section class="mx-auto max-w-7xl px-6 pt-16 md:pt-20 pb-12">
    <Ribbon color="red">About us</Ribbon>
    <h1 class="mt-6 font-display font-bold text-pm-ink text-5xl md:text-6xl tracking-tight leading-[0.98]">
      Built by parents.<br />Run by volunteers.
    </h1>
    <p class="mt-6 max-w-2xl text-lg md:text-xl text-pm-ink/75 leading-relaxed">
      Piedmont Makers is a 501(&zwnj;c)(3) nonprofit. We make sure every East Bay kid gets to build something they're proud of: robotics teams, a community engineering lab, an annual school maker faire, and STEAM grants for PUSD teachers.
    </p>
  </section>

  <!-- Mission + Vision -->
  <section class="mx-auto max-w-7xl px-6 pb-16">
    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-pm-cream-2/70 border-[3px] border-pm-ink p-8 md:p-10">
        <Ribbon color="red">Mission</Ribbon>
        <p class="mt-6 font-display text-2xl md:text-3xl tracking-tight leading-snug text-pm-ink">
          Engaging and inclusive S.T.E.A.M. experiences for young people in Piedmont, CA and beyond — through partnerships that develop and support educational programs.
        </p>
      </div>
      <div class="bg-pm-cream-2/70 border-[3px] border-pm-ink p-8 md:p-10">
        <Ribbon color="cyan">Vision</Ribbon>
        <p class="mt-6 font-display text-2xl md:text-3xl tracking-tight leading-snug text-pm-ink">
          Young people aspire and are empowered to be creative problem solvers and innovators in Science, Technology, Engineering, Arts, and Math.
        </p>
      </div>
    </div>

    <!-- The problem we solve -->
    <div class="mt-10 bg-pm-paper border-l-4 border-pm-purple p-8 md:p-10">
      <Ribbon color="purple">The problem we solve</Ribbon>
      <p class="mt-5 text-lg leading-relaxed text-pm-ink/85 max-w-3xl">
        Most kids never get their hands on a soldering iron, a 3D printer, or a working robot before high school. Especially kids whose schools or families can't easily afford the tools.
      </p>
      <p class="mt-3 text-pm-ink/80 leading-relaxed max-w-3xl">
        Research is consistent: early exposure to applied science and engineering increases persistence in STEAM coursework, improves confidence in problem solving, strengthens teamwork and communication skills, and influences future academic and career pathways. But these opportunities are too often limited by cost, equipment, space, or availability of trained mentors.
      </p>
      <p class="mt-3 text-pm-ink/80 leading-relaxed max-w-3xl">
        Piedmont Makers exists to close that gap: robotics leagues that older kids teach the younger ones in, teacher grants, shared facilities, and community events open to everyone.
      </p>
    </div>
  </section>

  <!-- Impact stats -->
  <section class="bg-pm-ink text-pm-cream">
    <div class="mx-auto max-w-7xl px-6 py-14 md:py-16">
      <div class="text-center mb-10">
        <Ribbon color="cyan">By the numbers</Ribbon>
        <h2 class="mt-5 font-display font-bold text-3xl md:text-4xl tracking-tight">The largest community-based youth robotics league in the US</h2>
      </div>
      <ul class="grid grid-cols-2 md:grid-cols-4 gap-y-8 gap-x-6 md:divide-x divide-pm-cream/15">
        {impactStats.map((s) => (
          <li class="text-center md:px-6">
            <p class:list={["font-display font-bold text-4xl md:text-5xl leading-none", s.color]}>{s.number}</p>
            <p class="mt-3 text-sm text-pm-cream/80 leading-snug">{s.label}</p>
          </li>
        ))}
      </ul>
      <p class="mt-10 text-center text-sm text-pm-cream/65 max-w-2xl mx-auto leading-relaxed">
        Plus an annual School Maker Faire that drew 1,000+ visitors and 80+ student exhibitors, a Highland Cup win in the 2025 Piedmont 4th of July Parade, a $245K capital campaign that built the Mary G. Ross Engineering Lab at Piedmont High School, and a multi-year lease on a permanent 10th Street robotics field in Oakland. 40% of LEGO League participants are girls; 87 students came from Title 1 schools.
      </p>
    </div>
  </section>

  <!-- Letter from leadership -->
  <section class="mx-auto max-w-7xl px-6 pt-20">
    <Ribbon color="red">A letter from leadership</Ribbon>
    <h2 class="mt-5 font-display font-bold text-4xl md:text-5xl tracking-tight leading-tight max-w-3xl">
      Hands-on learning changes how kids see themselves.
    </h2>
    <div class="mt-6 max-w-3xl space-y-4 text-lg text-pm-ink/80 leading-relaxed">
      <p>For Piedmont Makers, this was a year of building, literally. We built robots. We helped hundreds of students build confidence, problem-solving skills, and a sense of belonging in science and engineering spaces. We built a permanent home for youth robotics. We built new partnerships across the East Bay, and pathways for hundreds of kids who might not otherwise see themselves as engineers, scientists, or makers.</p>
      <p>When Piedmont Makers started over a decade ago, we imagined a community where every child could experience the joy of creating something with their hands, and their minds. This year, we served more students from more schools across more cities than ever before. We welcomed kids from Title 1 schools alongside kids from private academies. We watched girls lead robotics teams. We saw high schoolers teach elementary students how to use CAD software.</p>
      <p>None of this happens without you. The parents who volunteer as coaches. The teachers who stay late. The donors who believe that hands-on learning matters. The mentors who show up week after week.</p>
    </div>
    <p class="mt-6 font-display font-semibold text-pm-ink">
      Ben Stein &amp; Kevin Clark
      <span class="font-body italic text-pm-ink/65 text-base font-normal">— Co-Presidents</span>
    </p>
  </section>

  <!-- Board roster -->
  <section class="mx-auto max-w-7xl px-6 pt-20 pb-16">
    <Ribbon color="purple">Board of directors</Ribbon>
    <h2 class="mt-5 font-display font-bold text-4xl md:text-5xl tracking-tight leading-tight">
      The people doing the work.
    </h2>
    <p class="mt-5 max-w-2xl text-pm-ink/75 leading-relaxed">
      Twenty-three volunteer board members for the 2026–27 slate. Parents, alumni, and community members. Board terms run annually with elections at the spring board meeting.
    </p>

    <div class="mt-12 space-y-12">
      <div>
        <p class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55 border-b-2 border-pm-ink pb-3">Officers</p>
        <ul class="mt-6 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-5">
          {board.officers.map((m) => (
            <li>
              <p class="font-display font-bold text-lg tracking-tight">{m.name}</p>
              {m.role && <p class="text-sm text-pm-ink/65">{m.role}</p>}
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55 border-b-2 border-pm-ink pb-3">Robotics</p>
        <ul class="mt-6 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-5">
          {board.robotics.map((m) => (
            <li>
              <p class="font-display font-semibold tracking-tight">{m.name}</p>
              {m.role && <p class="text-sm text-pm-ink/65">{m.role}</p>}
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55 border-b-2 border-pm-ink pb-3">Events &amp; programs</p>
        <ul class="mt-6 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-5">
          {board.programs.map((m) => (
            <li>
              <p class="font-display font-semibold tracking-tight">{m.name}</p>
              {m.role && <p class="text-sm text-pm-ink/65">{m.role}</p>}
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55 border-b-2 border-pm-ink pb-3">At large</p>
        <ul class="mt-6 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-x-6 gap-y-3">
          {board.atLarge.map((m) => (
            <li>
              <p class="font-display font-semibold tracking-tight">{m.name}</p>
              {m.role && <p class="text-xs text-pm-ink/65">{m.role}</p>}
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55 border-b-2 border-pm-ink pb-3">Staff</p>
        <ul class="mt-6 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-5">
          {board.staff.map((m) => (
            <li>
              <p class="font-display font-semibold tracking-tight">{m.name}</p>
              {m.role && <p class="text-sm text-pm-ink/65">{m.role}</p>}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Contact + legal -->
  <section class="bg-pm-cream-2/60">
    <div class="mx-auto max-w-7xl px-6 py-20 grid md:grid-cols-12 gap-10">
      <div class="md:col-span-7">
        <Ribbon color="red">Contact</Ribbon>
        <h2 class="mt-5 font-display font-bold text-4xl tracking-tight leading-tight">
          Email is the best way to reach us.
        </h2>
        <p class="mt-5 text-lg text-pm-ink/75 leading-relaxed max-w-xl">
          For general questions, partnership inquiries, donor questions, or to volunteer, start with the general inbox and we'll route from there.
        </p>
        <div class="mt-8 space-y-3">
          <a href="mailto:hello@piedmontmakers.org" class="group flex items-center justify-between gap-4 bg-pm-paper border-[3px] border-pm-ink p-5 hover:bg-white transition-colors">
            <div>
              <p class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55">General inquiries</p>
              <p class="mt-1 font-display font-bold text-xl tracking-tight">hello@piedmontmakers.org</p>
            </div>
            <span class="font-display text-pm-red group-hover:translate-x-1 transition-transform">→</span>
          </a>
          <a href="mailto:robotics@piedmontmakers.org" class="group flex items-center justify-between gap-4 bg-pm-paper border-[3px] border-pm-ink p-5 hover:bg-white transition-colors">
            <div>
              <p class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55">Robotics-specific</p>
              <p class="mt-1 font-display font-bold text-xl tracking-tight">robotics@piedmontmakers.org</p>
            </div>
            <span class="font-display text-pm-red group-hover:translate-x-1 transition-transform">→</span>
          </a>
        </div>
      </div>
      <div class="md:col-span-5">
        <Ribbon color="ink">Legal</Ribbon>
        <dl class="mt-6 space-y-4 font-body">
          <div>
            <dt class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55">Legal name</dt>
            <dd class="mt-0.5 font-semibold">Piedmont Makers</dd>
          </div>
          <div>
            <dt class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55">Status</dt>
            <dd class="mt-0.5 font-semibold">501(&zwnj;c)(3) nonprofit corporation</dd>
          </div>
          <div>
            <dt class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55">EIN</dt>
            <dd class="mt-0.5 font-semibold font-mono">47-2831568</dd>
          </div>
        </dl>
        <div class="mt-8">
          <a href="https://donate.piedmontmakers.org" class="ribbon bg-pm-red text-white text-base hover:bg-pm-red-deep transition-colors">
            Make a tax-deductible donation
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
