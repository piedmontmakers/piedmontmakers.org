---
import BaseLayout from "../layouts/BaseLayout.astro";
import Ribbon from "../components/Ribbon.astro";
import PhotoCard from "../components/PhotoCard.astro";
import Banner from "../components/Banner.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (path: string) => `${base}${path}`;

const challenges = [
  {
    name: "Technical",
    blurb: "Build a device or invention that performs a task. Mechanisms, contraptions, working prototypes.",
  },
  {
    name: "Scientific",
    blurb: "Investigate a real-world phenomenon and present what you learned. Research, models, experiments.",
  },
  {
    name: "Engineering",
    blurb: "Design a structure that holds weight, withstands force, or solves a structural problem.",
  },
  {
    name: "Fine Arts",
    blurb: "Tell a story through performance, visual art, and design. Theater meets making.",
  },
  {
    name: "Improvisational",
    blurb: "Research a topic, then improvise a sketch on a twist revealed at the tournament.",
  },
  {
    name: "Service Learning",
    blurb: "Identify a community need and act on it. Document the impact and share what changed.",
  },
  {
    name: "Rising Stars!",
    blurb: "Non-competitive K-2 introduction. Kids try the creative-problem-solving process at their own pace.",
  },
];

const levels = [
  { name: "Early Learning", grades: "PK-2", note: "Non-competitive" },
  { name: "Elementary", grades: "Grades 3-5" },
  { name: "Middle", grades: "Grades 6-8" },
  { name: "Secondary", grades: "Grades 9-12" },
];

const seasonSteps = [
  {
    when: "Fall",
    what: "Challenges released. Teams form (up to 7 kids), pick one of the seven challenges, and start designing a solution.",
  },
  {
    when: "Winter",
    what: "Build, rehearse, refine. Teams meet weekly with a team manager (a parent volunteer, not a coach in the teaching sense).",
  },
  {
    when: "Spring",
    what: "Regional tournament, then the California State Tournament. Top teams advance to Global Finals.",
  },
  {
    when: "May",
    what: "Global Finals at the University of Tennessee in Knoxville. Teams from across the U.S. and 30+ countries.",
  },
];
---

<BaseLayout
  title="Destination Imagination — Piedmont Makers"
  description="Piedmont Makers is piloting Destination Imagination in Fall 2026: a team-based creative problem-solving program for K-12 students, in partnership with California Destination Imagination."
>
  <!-- Hero -->
  <section class="mx-auto max-w-7xl px-6 pt-16 md:pt-20 pb-8">
    <a href={link("/events")} class="font-display font-semibold text-pm-ink hover:text-pm-red underline-offset-4 hover:underline">
      ← All events &amp; programs
    </a>
    <div class="mt-6 grid md:grid-cols-12 gap-10 md:gap-12 items-start">
      <div class="md:col-span-7">
        <Ribbon color="cyan">Destination Imagination</Ribbon>
        <h1 class="mt-6 font-display font-bold text-pm-ink text-5xl md:text-6xl tracking-tight leading-[0.98]">
          Creative problem-solving as a team sport.
        </h1>
        <p class="mt-7 text-lg md:text-xl text-pm-ink/75 leading-relaxed">
          Destination Imagination (DI) is a global program where teams of up to seven kids pick an open-ended challenge each fall, spend the school year building a solution, and present it at a spring tournament. K through 12. No experience required.
        </p>
        <p class="mt-4 text-pm-ink/75 leading-relaxed">
          We&apos;re piloting DI in the East Bay starting fall 2026, in partnership with <a href="https://www.caldi.org" target="_blank" rel="noopener" class="font-display font-semibold underline underline-offset-4 decoration-pm-cyan hover:text-pm-cyan-deep">California Destination Imagination</a>.
        </p>
      </div>
      <div class="md:col-span-5">
        <!-- TODO: replace with a DI-specific photo when we have one from the pilot season. -->
        <PhotoCard
          caption="Kids building together at a popup maker space"
          color="cyan"
          tilt="right"
          aspect="square"
          src="/img/programs/popup.jpg"
          alt="Children working together on a building project at long tables in a community hall."
        />
      </div>
    </div>
  </section>

  <!-- Pilot announcement banner -->
  <section class="mx-auto max-w-7xl px-6 pb-4">
    <Banner
      eyebrow="Pilot · Fall 2026"
      headline="New this season."
      body="We're standing up our first DI teams this fall. Details about coach training, team formation, and where teams will meet are coming together now. Subscribe to the newsletter to hear when sign-ups open."
      color="cyan"
    />
  </section>

  <!-- What is DI -->
  <section class="mx-auto max-w-7xl px-6 py-12">
    <Ribbon color="cyan">How it works</Ribbon>
    <h2 class="mt-5 font-display font-bold text-3xl md:text-4xl tracking-tight leading-tight">
      Two parts: a season-long Team Challenge and a surprise Instant Challenge.
    </h2>
    <div class="mt-8 grid md:grid-cols-2 gap-6">
      <article class="bg-pm-paper border-[3px] border-pm-ink p-7 md:p-8">
        <p class="font-display text-xs uppercase tracking-[0.18em] text-pm-cyan-deep">Team Challenge</p>
        <h3 class="mt-2 font-display font-bold text-2xl tracking-tight leading-tight">
          Eight months of work, one eight-minute presentation.
        </h3>
        <p class="mt-4 text-pm-ink/80 leading-relaxed">
          Each team picks one of seven open-ended challenges in September and spends the school year on it. Research, design, build, rehearse. Adults can&apos;t do the work for them. Interference rules are strict, and that&apos;s part of the point.
        </p>
      </article>
      <article class="bg-pm-paper border-[3px] border-pm-ink p-7 md:p-8">
        <p class="font-display text-xs uppercase tracking-[0.18em] text-pm-purple">Instant Challenge</p>
        <h3 class="mt-2 font-display font-bold text-2xl tracking-tight leading-tight">
          A problem they&apos;ve never seen, solved in five to eight minutes.
        </h3>
        <p class="mt-4 text-pm-ink/80 leading-relaxed">
          At every tournament, each team walks into a room and gets a brand-new problem with a small pile of materials. Sometimes it&apos;s a building task, sometimes performance, sometimes both. Practiced through the year; revealed cold on the day.
        </p>
      </article>
    </div>
  </section>

  <!-- Seven challenge tracks -->
  <section class="mx-auto max-w-7xl px-6 py-12">
    <Ribbon color="cyan">Seven challenge tracks</Ribbon>
    <h2 class="mt-5 font-display font-bold text-3xl md:text-4xl tracking-tight leading-tight">
      Pick the flavor that fits your team.
    </h2>
    <p class="mt-4 max-w-2xl text-pm-ink/75 leading-relaxed">
      Specific challenge prompts change each year. The categories don&apos;t. A team that loves theater can find a home alongside a team that loves circuits.
    </p>
    <ul class="mt-8 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {challenges.map((c) => (
        <li class="bg-pm-paper border-[3px] border-pm-ink p-5">
          <p class="font-display font-bold text-lg tracking-tight">{c.name}</p>
          <p class="mt-2 text-sm text-pm-ink/75 leading-relaxed">{c.blurb}</p>
        </li>
      ))}
    </ul>
  </section>

  <!-- Age levels -->
  <section class="mx-auto max-w-7xl px-6 py-12">
    <Ribbon color="cyan">Every grade band</Ribbon>
    <h2 class="mt-5 font-display font-bold text-3xl md:text-4xl tracking-tight leading-tight">
      From PK kids exploring the process to high schoolers competing for Global Finals.
    </h2>
    <ul class="mt-8 grid grid-cols-2 md:grid-cols-4 gap-4">
      {levels.map((lvl) => (
        <li class="bg-pm-paper border-[3px] border-pm-ink p-5 text-center">
          <p class="font-display font-bold text-xl tracking-tight">{lvl.name}</p>
          <p class="mt-1 font-display text-sm text-pm-ink/65">{lvl.grades}</p>
          {lvl.note && (
            <p class="mt-2 font-marker text-base text-pm-purple">{lvl.note}</p>
          )}
        </li>
      ))}
    </ul>
  </section>

  <!-- Season timeline -->
  <section class="bg-pm-cream-2/60 mt-12">
    <div class="mx-auto max-w-7xl px-6 py-16">
      <Ribbon color="cyan">The season</Ribbon>
      <h2 class="mt-5 font-display font-bold text-3xl md:text-4xl tracking-tight leading-tight">
        A school-year arc, ending in a spring tournament.
      </h2>
      <ol class="mt-8 space-y-5 max-w-3xl">
        {seasonSteps.map((step) => (
          <li class="grid grid-cols-[6rem_1fr] md:grid-cols-[8rem_1fr] gap-4 md:gap-6 items-start">
            <span class="font-display font-bold text-pm-cyan-deep text-lg md:text-xl tracking-tight">{step.when}</span>
            <span class="text-pm-ink/80 leading-relaxed">{step.what}</span>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Cal DI partnership -->
  <section class="mx-auto max-w-7xl px-6 py-16">
    <div class="grid md:grid-cols-12 gap-10 items-center">
      <div class="md:col-span-7">
        <Ribbon color="cyan">Partnership</Ribbon>
        <h2 class="mt-5 font-display font-bold text-3xl md:text-4xl tracking-tight leading-tight">
          Why we&apos;re piloting DI alongside our robotics teams.
        </h2>
        <p class="mt-5 text-lg text-pm-ink/75 leading-relaxed">
          Robotics is one path into hands-on STEAM. DI is a different one, with a wider front door. The challenge tracks reach kids who love theater, writing, and visual art as readily as kids who love mechanisms. Teams stay small (up to seven), and adults stay out of the work.
        </p>
        <p class="mt-4 text-pm-ink/75 leading-relaxed">
          <a href="https://www.caldi.org" target="_blank" rel="noopener" class="font-display font-semibold underline underline-offset-4 decoration-pm-cyan hover:text-pm-cyan-deep">California Destination Imagination</a> is the statewide affiliate that runs regional and state tournaments. They&apos;ve been doing this in California since the 1980s and are helping us launch.
        </p>
      </div>
      <div class="md:col-span-5">
        <PhotoCard
          caption="Build Like a Girl mentoring: older kids leading younger ones"
          color="cyan"
          tilt="left"
          tape="left"
          aspect="square"
          src="/img/programs/build-like-a-girl.jpg"
          alt="High school students in purple Piedmont Makers sweatshirts working alongside younger students on a hands-on build."
        />
      </div>
    </div>
  </section>

  <!-- Get involved -->
  <section class="bg-pm-ink text-pm-cream">
    <div class="mx-auto max-w-7xl px-6 py-16 md:py-20">
      <Ribbon color="cyan">Get involved</Ribbon>
      <h2 class="mt-5 font-display font-bold text-3xl md:text-4xl tracking-tight max-w-3xl">
        Team managers, families, and host venues wanted.
      </h2>
      <div class="mt-8 grid md:grid-cols-3 gap-6">
        <div>
          <p class="font-display font-bold text-xl tracking-tight">Team managers</p>
          <p class="mt-2 text-pm-cream/80 leading-relaxed">
            DI&apos;s version of a coach. No technical background required. The training Cal DI provides covers everything; what matters most is consistency through the season.
          </p>
        </div>
        <div>
          <p class="font-display font-bold text-xl tracking-tight">Families</p>
          <p class="mt-2 text-pm-cream/80 leading-relaxed">
            If you have a kid (or a pair of friends) interested, tell us. Teams form in the fall and meet weekly. Most teams are mixed-grade within a level.
          </p>
        </div>
        <div>
          <p class="font-display font-bold text-xl tracking-tight">Host venues</p>
          <p class="mt-2 text-pm-cream/80 leading-relaxed">
            Teams meet weekly somewhere quiet with tables, power, and tolerance for cardboard scraps. Same kind of space as our popup maker spaces.
          </p>
        </div>
      </div>
      <p class="mt-10 text-pm-cream/85 leading-relaxed max-w-2xl">
        Interested in any of the above? Email <a href="mailto:hello@piedmontmakers.org" class="font-display font-semibold underline underline-offset-4 decoration-pm-cyan hover:text-pm-cyan">hello@piedmontmakers.org</a> and we&apos;ll loop you into the pilot planning. Registration windows and team-manager training dates will land in <a href={link("/#newsletter")} class="font-display font-semibold underline underline-offset-4 decoration-pm-cyan hover:text-pm-cyan">the newsletter</a>.
      </p>
    </div>
  </section>
</BaseLayout>
