---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Ribbon from "../../components/Ribbon.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (path: string) => `${base}${path}`;
const asset = (path: string) => `${base}${path.startsWith("/") ? path : `/${path}`}`;

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// timeZone: "UTC" because YAML dates parse as midnight UTC; without it the
// displayed day shifts back one on West-Coast / non-UTC builds.
const formatDate = (d: Date) =>
  d.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric", timeZone: "UTC" });

// Posts without a hero image fall back to Makey on his purple background —
// distinctive, on-brand, no fabricated photos.
const fallbackThumb = "/img/brand/makey.png";
---

<BaseLayout title="Blog — Piedmont Makers" description="News, project recaps, and updates from Piedmont Makers.">
  <section class="mx-auto max-w-7xl px-6 pt-16 md:pt-20 pb-12">
    <Ribbon color="red">Blog</Ribbon>
    <h1 class="mt-6 font-display font-bold text-pm-ink text-5xl md:text-6xl tracking-tight leading-[0.98]">
      What we&apos;ve been up to.
    </h1>
    <p class="mt-6 max-w-2xl text-lg text-pm-ink/75 leading-relaxed">
      A running log of what we&apos;re up to. For sign-up windows, event dates, and anything time-sensitive, the <a href={link("/#newsletter")} class="font-display font-semibold underline underline-offset-4 decoration-pm-red hover:text-pm-red">newsletter</a> is faster.
    </p>
    <p class="mt-5">
      <a
        href={link("/rss.xml")}
        class="inline-flex items-center gap-2 font-display text-sm font-semibold text-pm-ink hover:text-pm-red transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4" aria-hidden="true">
          <path d="M5.5 4.5a1 1 0 0 1 1-1c8.836 0 16 7.164 16 16a1 1 0 1 1-2 0c0-7.732-6.268-14-14-14a1 1 0 0 1-1-1Zm0 5a1 1 0 0 1 1-1c6.075 0 11 4.925 11 11a1 1 0 1 1-2 0c0-4.97-4.03-9-9-9a1 1 0 0 1-1-1Zm2.5 6.75a2.25 2.25 0 1 1 0 4.5 2.25 2.25 0 0 1 0-4.5Z" />
        </svg>
        Subscribe via RSS
      </a>
    </p>
  </section>

  <section class="mx-auto max-w-7xl px-6 pb-20 md:pb-28">
    <ul class="space-y-2 divide-y divide-pm-ink/10">
      {posts.map((post) => {
        const hasHero = !!post.data.heroImage;
        const thumbSrc = asset(post.data.heroImage || fallbackThumb);
        const thumbAlt = post.data.heroImageAlt || (hasHero ? post.data.title : "Makey, the Piedmont Makers mascot");
        return (
          <li class="pt-8 first:pt-0">
            <a href={link(`/blog/${post.id}`)} class="group grid grid-cols-1 sm:grid-cols-[180px_1fr] md:grid-cols-[220px_1fr] gap-5 md:gap-7">
              <div class:list={["aspect-square overflow-hidden border-[3px] border-pm-ink", hasHero ? "" : "bg-pm-purple flex items-center justify-center p-6"]}>
                <img
                  src={thumbSrc}
                  alt={thumbAlt}
                  class:list={["w-full h-full", hasHero ? "object-cover" : "object-contain"]}
                  loading="lazy"
                />
              </div>
              <div>
                <p class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55">{formatDate(post.data.pubDate)}</p>
                <h2 class="mt-2 font-display font-bold text-2xl md:text-3xl tracking-tight leading-tight group-hover:text-pm-red transition-colors">
                  {post.data.title}
                </h2>
                {post.data.excerpt && (
                  <p class="mt-3 text-lg text-pm-ink/75 leading-relaxed">{post.data.excerpt}</p>
                )}
                <p class="mt-4 font-display font-semibold text-pm-ink group-hover:text-pm-red transition-colors">
                  Read post →
                </p>
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  </section>
</BaseLayout>
