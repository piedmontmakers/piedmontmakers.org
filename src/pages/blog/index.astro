---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Ribbon from "../../components/Ribbon.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (path: string) => `${base}${path}`;

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const formatDate = (d: Date) =>
  d.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" });
---

<BaseLayout title="Blog — Piedmont Makers" description="News, project recaps, and updates from Piedmont Makers.">
  <section class="mx-auto max-w-5xl px-6 pt-16 md:pt-20 pb-12">
    <Ribbon color="red">Blog</Ribbon>
    <h1 class="mt-6 font-display font-bold text-pm-ink text-5xl md:text-6xl tracking-tight leading-[0.98]">
      News, recaps, and the occasional photo.
    </h1>
    <p class="mt-6 max-w-2xl text-lg text-pm-ink/75 leading-relaxed">
      A running log of what we&apos;re up to. For things you actually need to act on — sign-up windows, event dates — the <a href="/piedmontmakers.org/#newsletter" class="font-display font-semibold underline underline-offset-4 decoration-pm-red hover:text-pm-red">newsletter</a> is faster.
    </p>
  </section>

  <section class="mx-auto max-w-5xl px-6 pb-20 md:pb-28">
    <ul class="space-y-8 divide-y divide-pm-ink/10">
      {posts.map((post) => (
        <li class="pt-8 first:pt-0">
          <a href={link(`/blog/${post.id}`)} class="group block">
            <p class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55">{formatDate(post.data.pubDate)}</p>
            <h2 class="mt-2 font-display font-bold text-3xl md:text-4xl tracking-tight leading-tight group-hover:text-pm-red transition-colors">
              {post.data.title}
            </h2>
            {post.data.excerpt && (
              <p class="mt-3 text-lg text-pm-ink/75 leading-relaxed max-w-2xl">{post.data.excerpt}</p>
            )}
            <p class="mt-4 font-display font-semibold text-pm-ink group-hover:text-pm-red transition-colors">
              Read post →
            </p>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
