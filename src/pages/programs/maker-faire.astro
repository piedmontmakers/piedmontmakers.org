---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Ribbon from "../../components/Ribbon.astro";
import PhotoCard from "../../components/PhotoCard.astro";
import FAQ from "../../components/FAQ.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (path: string) => `${base}${path}`;

const faqItems = [
  {
    q: "Is admission really free?",
    a: "Yes. Admission is free — we just ask people to register on Eventbrite so we have a rough headcount for the day.",
  },
  {
    q: "What ages is the faire for?",
    a: "All ages. Most exhibits come from K-12 students in PUSD, but the audience is the whole community. Kids, parents, grandparents, neighbors, anyone curious about what local students are making.",
  },
  {
    q: "Can my kid (or my class) exhibit?",
    a: "Yes. The exhibit signup form is open in the spring. Any project type works — drones, cosplay, puppets, kites, VR, LEGO creations, music, ceramics, anything you made and want to talk about. Use the exhibitor signup link above.",
  },
  {
    q: "How do I volunteer?",
    a: "Setup, cleanup, logistics, helping exhibitors during the day. Sign up via the Grasshopper link above. Most volunteer shifts are short (1-2 hours) and you can pick what fits your day.",
  },
  {
    q: "Where is parking?",
    a: "Piedmont High School has limited parking. We recommend walking or biking if you can; otherwise plan to arrive a little early and find street parking in the surrounding neighborhood.",
  },
  {
    q: "Is it indoors or outdoors?",
    a: "Mostly indoors. The big main floor is inside the high school; some larger exhibits and demos may be outside in good weather.",
  },
];
---

<BaseLayout
  title="School Maker Faire — Piedmont Makers"
  description="The 12th Annual Piedmont School Maker Faire is Sunday, May 17, 2026, 11am-3pm at Piedmont High School. Free, open to the public."
>
  <!-- Hero -->
  <section class="mx-auto max-w-5xl px-6 pt-16 md:pt-20 pb-8">
    <a href={link("/programs")} class="font-display font-semibold text-pm-ink hover:text-pm-red underline-offset-4 hover:underline">
      ← All programs
    </a>
    <div class="mt-6">
      <Ribbon color="red">12th Annual</Ribbon>
    </div>
    <h1 class="mt-6 font-display font-bold text-pm-ink text-5xl md:text-7xl tracking-tight leading-[0.95]">
      The Piedmont School<br />Maker Faire.
    </h1>
    <p class="mt-7 max-w-2xl text-lg md:text-xl text-pm-ink/75 leading-relaxed">
      K-12 Science, Technology, Engineering, Arts and Math — for the Piedmont community and beyond. Free admission. One day, hundreds of student-built projects, no homework.
    </p>
  </section>

  <!-- Event details + CTAs -->
  <section class="mx-auto max-w-5xl px-6 py-12">
    <div class="grid md:grid-cols-12 gap-8">
      <div class="md:col-span-7 bg-pm-cream-2/70 border-[3px] border-pm-ink p-7 md:p-9">
        <p class="font-marker text-2xl text-pm-purple">save the date —</p>
        <h2 class="mt-2 font-display font-bold text-3xl md:text-4xl tracking-tight leading-tight">
          Sunday, May 17, 2026
        </h2>
        <dl class="mt-6 space-y-3 font-body">
          <div class="flex gap-4">
            <dt class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55 w-24 shrink-0">Time</dt>
            <dd class="font-semibold">11:00am — 3:00pm</dd>
          </div>
          <div class="flex gap-4">
            <dt class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55 w-24 shrink-0">Location</dt>
            <dd class="font-semibold">Piedmont High School</dd>
          </div>
          <div class="flex gap-4">
            <dt class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55 w-24 shrink-0">Admission</dt>
            <dd class="font-semibold">Free · Eventbrite registration encouraged</dd>
          </div>
          <div class="flex gap-4">
            <dt class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55 w-24 shrink-0">Audience</dt>
            <dd class="font-semibold">All ages</dd>
          </div>
        </dl>
        <a
          href="https://www.eventbrite.com/e/12th-annual-piedmont-school-maker-faire-tickets-1987744231505"
          class="mt-8 inline-flex items-center gap-2 ribbon bg-pm-red text-white text-base hover:bg-pm-red-deep transition-colors"
        >
          Get tickets on Eventbrite →
        </a>
      </div>
      <div class="md:col-span-5 space-y-3">
        <a
          href="https://docs.google.com/forms/d/e/1FAIpQLSe_oL4UXCNJnETrYTlnWwD-Vg71smX2i-kzt6tV9LlDowgczA/viewform"
          class="group block bg-pm-paper border-[3px] border-pm-ink p-5 hover:bg-white transition-colors"
        >
          <p class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55">For exhibitors</p>
          <p class="mt-1 font-display font-bold text-xl md:text-2xl tracking-tight leading-tight">Sign up to exhibit →</p>
          <p class="mt-2 text-sm text-pm-ink/65 leading-relaxed">Show off something you made. All project types welcome.</p>
        </a>
        <a
          href="https://grasshoppersignup.com/s/qo1qew"
          class="group block bg-pm-paper border-[3px] border-pm-ink p-5 hover:bg-white transition-colors"
        >
          <p class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55">For volunteers</p>
          <p class="mt-1 font-display font-bold text-xl md:text-2xl tracking-tight leading-tight">Volunteer at the faire →</p>
          <p class="mt-2 text-sm text-pm-ink/65 leading-relaxed">Setup, cleanup, logistics, exhibit support. Short shifts, real impact.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- What to expect -->
  <section class="mx-auto max-w-5xl px-6 py-12">
    <Ribbon color="cyan">What to expect</Ribbon>
    <div class="mt-6 grid md:grid-cols-2 gap-8">
      <div>
        <h2 class="font-display font-bold text-3xl tracking-tight leading-tight">A working room of student makers.</h2>
        <p class="mt-4 text-lg text-pm-ink/75 leading-relaxed">
          80+ exhibitor tables. K-12 students demoing what they built this year — robots that drive, kites that fly, costumes that light up, ceramics fresh out of the kiln, board games of dubious balance, baked goods that taste better than they should.
        </p>
        <p class="mt-3 text-pm-ink/75 leading-relaxed">
          Past faires have drawn 1,000+ community members across the four hours. You can wander, ask questions, try things, and stay for as long as you want.
        </p>
      </div>
      <div>
        <PhotoCard caption="Photo: a Maker Faire exhibit with a working robot" color="cyan" tilt="right" aspect="landscape" />
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mx-auto max-w-4xl px-6 py-12">
    <Ribbon color="purple">FAQ</Ribbon>
    <h2 class="mt-5 font-display font-bold text-3xl md:text-4xl tracking-tight">
      Common questions.
    </h2>
    <div class="mt-8">
      <FAQ items={faqItems} />
    </div>
    <p class="mt-6 text-pm-ink/75">
      Still have something specific? Email <a href="mailto:hello@piedmontmakers.org" class="font-display font-semibold underline underline-offset-4 decoration-pm-red hover:text-pm-red">hello@piedmontmakers.org</a>.
    </p>
  </section>

  <!-- Past faires -->
  <section class="mx-auto max-w-5xl px-6 py-16">
    <div class="rounded-3xl bg-pm-ink text-pm-cream p-10 md:p-14">
      <Ribbon color="cyan">11 years and counting</Ribbon>
      <h2 class="mt-5 font-display font-bold text-3xl md:text-4xl tracking-tight">
        The faire has happened every spring since 2014.
      </h2>
      <p class="mt-5 max-w-2xl text-pm-cream/85 leading-relaxed">
        Last year's faire featured 80+ exhibits and drew over 1,000 visitors over four hours. The 11th annual faire was held May 11, 2025.
      </p>
      <p class="mt-3 max-w-2xl text-pm-cream/75 leading-relaxed">
        Full event history lives on the <a href={link("/events")} class="font-display font-semibold underline underline-offset-4 decoration-pm-red hover:text-pm-red">events calendar</a> — scroll down to "Past events."
      </p>
    </div>
  </section>
</BaseLayout>
