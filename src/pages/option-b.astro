---
import AltLayout from "../layouts/AltLayout.astro";
import Geometric from "../components/option-b/Geometric.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (path: string) => `${base}${path}`;

const programs = [
  { name: "FLL EXPLORE",  ages: "AGES 5–9",   tag: "K–3rd",   blurb: "A gentle intro to robotics with LEGO Education kits.",         color: "red" as const,    shape: "circle" as const },
  { name: "FLL CHALLENGE", ages: "AGES 9–14",  tag: "4–8TH",   blurb: "Build LEGO robots, run autonomous missions, present a project.", color: "cyan" as const,   shape: "plus" as const },
  { name: "FTC ROBOTICS",  ages: "AGES 12–18", tag: "7–12TH",  blurb: "Custom metal robots, Java programming, regional competitions.",  color: "purple" as const, shape: "triangle" as const },
  { name: "FRC TEAM 8627", ages: "AGES 14–18", tag: "HIGH SCHOOL", blurb: "120-lb competition robots, real build season, full engineering.", color: "red" as const,    shape: "rings" as const },
  { name: "MAKER FAIRE",   ages: "ALL AGES",   tag: "EACH MAY", blurb: "K-12 students show what they made all year.",                  color: "cyan" as const,   shape: "half-circle-top" as const },
  { name: "TECH SOCIAL",   ages: "ALL AGES",   tag: "1ST FRI",  blurb: "Speaker, free dinner, hangout for the maker community.",      color: "purple" as const, shape: "dots" as const },
];
---

<AltLayout title="Piedmont Makers — Option B — Bold modular geometric">
  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div class="mx-auto max-w-7xl px-6 pt-12 md:pt-16 pb-20">
      <!-- Eyebrow row with mono label and geometric accents -->
      <div class="flex items-center gap-3 mb-10">
        <Geometric shape="plus" color="red" class="w-5 h-5" />
        <span class="font-mono text-xs font-semibold tracking-[0.18em] uppercase text-pm-ink/70">
          Welcome / Piedmont, CA / Est. 2014
        </span>
      </div>

      <div class="grid md:grid-cols-12 gap-10 items-end">
        <div class="md:col-span-7">
          <h1 class="font-display font-bold text-pm-ink text-6xl md:text-7xl lg:text-8xl leading-[0.92]">
            <span class="block">Build,</span>
            <span class="block text-pm-red">tinker,</span>
            <span class="block">teach,</span>
            <span class="block text-pm-cyan">repeat.</span>
          </h1>
          <p class="mt-8 max-w-xl text-lg md:text-xl text-pm-ink/75 leading-relaxed">
            Piedmont Makers runs robotics teams, an engineering lab, a school maker faire, and a monthly tech speaker series — all volunteer-run, mostly free, for kids and the adults who love them.
          </p>
          <div class="mt-10 flex flex-wrap items-center gap-3">
            <a href={link("/robotics")} class="inline-flex items-center gap-2 bg-pm-red text-white font-display font-semibold px-6 py-3 hover:bg-pm-red-deep transition-colors">
              Sign your kid up →
            </a>
            <a href={link("/community")} class="inline-flex items-center gap-2 border-[3px] border-pm-ink text-pm-ink font-display font-semibold px-6 py-[10px] hover:bg-pm-ink hover:text-pm-cream transition-colors">
              What we do
            </a>
          </div>
        </div>

        <!-- Photo block with geometric accents -->
        <div class="md:col-span-5 relative">
          <!-- Decorative shapes positioned around the photo frame -->
          <div class="absolute -top-6 -left-6 w-12 h-12 z-10">
            <Geometric shape="circle" color="cyan" />
          </div>
          <div class="absolute -bottom-6 -right-6 w-16 h-16 z-10">
            <Geometric shape="plus" color="red" />
          </div>
          <div class="absolute top-1/2 -right-4 w-8 h-8 z-10">
            <Geometric shape="triangle" color="purple" />
          </div>

          <!-- Single big photo placeholder with thick border -->
          <div class="border-[5px] border-pm-ink bg-pm-cyan aspect-[4/5] relative">
            <div class="absolute top-0 left-0 bg-pm-ink text-pm-cream font-mono text-[10px] tracking-widest uppercase px-3 py-1.5">
              FILE 001
            </div>
            <div class="absolute bottom-4 left-4 right-4">
              <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-white/70 block">Photograph</span>
              <span class="block font-display font-semibold text-white text-lg leading-tight mt-1">FRC Team 8627<br />at the championship</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROGRAMS — modular grid with big numerals -->
  <section class="relative bg-pm-cream-2/40 border-y-[3px] border-pm-ink">
    <div class="mx-auto max-w-7xl px-6 py-16 md:py-20">
      <div class="grid md:grid-cols-12 gap-8 items-end mb-12">
        <div class="md:col-span-8">
          <div class="flex items-center gap-3">
            <span class="font-mono text-xs font-semibold tracking-[0.18em] uppercase text-pm-ink/70">Section 01 / Programs</span>
            <div class="h-px flex-1 bg-pm-ink/20"></div>
          </div>
          <h2 class="mt-4 font-display font-bold text-4xl md:text-6xl tracking-tight leading-[0.95]">
            Pick the right program for your kid&apos;s age.
          </h2>
        </div>
        <div class="md:col-span-4 md:text-right">
          <a href={link("/robotics")} class="inline-flex items-center gap-2 font-display font-semibold text-pm-ink border-b-2 border-pm-ink pb-0.5 hover:text-pm-red hover:border-pm-red transition-colors">
            See all programs →
          </a>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-0 border-[3px] border-pm-ink">
        {programs.map((p, i) => {
          const colorBg = { red: "bg-pm-red", cyan: "bg-pm-cyan", purple: "bg-pm-purple" }[p.color];
          const showRightBorder = (i % 3) !== 2 ? "lg:border-r-[3px]" : "";
          const showBottomBorder = i < programs.length - 3 ? "lg:border-b-[3px]" : "";
          const smRightBorder = (i % 2) === 0 ? "sm:border-r-[3px]" : "";
          const smBottomBorder = i < programs.length - 2 ? "sm:border-b-[3px]" : "";
          return (
            <article class:list={["bg-pm-paper border-pm-ink", "border-b-[3px] sm:border-b-0 last:border-b-0", smRightBorder, smBottomBorder, showRightBorder, showBottomBorder]}>
              <a href={link("/robotics")} class="block group">
                <!-- Photo area with shape accent -->
                <div class:list={["relative aspect-[4/3]", colorBg]}>
                  <div class="absolute top-4 left-4 right-4 flex items-start justify-between">
                    <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-white/80 bg-pm-ink/30 backdrop-blur px-2 py-1">
                      {String(i + 1).padStart(2, "0")} / PHOTO
                    </span>
                    <div class="w-12 h-12 opacity-90">
                      <Geometric shape={p.shape} color="cream" />
                    </div>
                  </div>
                </div>
                <!-- Card body -->
                <div class="p-6 md:p-7">
                  <p class="font-mono text-xs font-semibold tracking-[0.18em] text-pm-ink/60">{p.ages} · {p.tag}</p>
                  <h3 class="mt-2 font-display font-bold text-2xl md:text-3xl tracking-tight">{p.name}</h3>
                  <p class="mt-3 text-pm-ink/80 leading-relaxed">{p.blurb}</p>
                  <p class="mt-5 inline-flex items-center gap-2 font-display font-semibold text-pm-ink group-hover:text-pm-red transition-colors">
                    Learn more <span class="group-hover:translate-x-1 transition-transform">→</span>
                  </p>
                </div>
              </a>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- THIS YEAR — full-bleed cyan band -->
  <section class="relative bg-pm-cyan text-white overflow-hidden">
    <!-- Decorative shapes -->
    <div class="absolute -top-12 -right-12 w-64 h-64 opacity-25">
      <Geometric shape="rings" color="cream" />
    </div>
    <div class="absolute -bottom-16 left-16 w-40 h-40 opacity-25">
      <Geometric shape="dots" color="cream" />
    </div>

    <div class="relative mx-auto max-w-7xl px-6 py-20 md:py-24">
      <div class="flex items-center gap-3 mb-6">
        <span class="font-mono text-xs font-semibold tracking-[0.18em] uppercase">Section 02 / Calendar 2026</span>
        <div class="h-px w-16 bg-white/40"></div>
      </div>
      <h2 class="font-display font-bold text-4xl md:text-6xl tracking-tight leading-[0.95] max-w-3xl">
        What&apos;s coming up at Piedmont Makers.
      </h2>

      <div class="mt-12 grid md:grid-cols-2 gap-6">
        <a href={link("/school-maker-faire")} class="group block bg-pm-paper text-pm-ink border-[5px] border-pm-ink p-7 hover:bg-white transition-colors">
          <div class="flex items-start justify-between">
            <span class="font-mono text-xs font-semibold tracking-[0.18em] uppercase text-pm-red">Sat May 17 · 2026</span>
            <div class="w-8 h-8 opacity-80">
              <Geometric shape="circle" color="red" />
            </div>
          </div>
          <h3 class="mt-3 font-display font-bold text-3xl tracking-tight leading-tight">12th Annual School Maker Faire</h3>
          <p class="mt-3 text-pm-ink/75 leading-relaxed">K-12 students show what they made all year. Free, open to the public, all day at the Veterans&apos; Building.</p>
          <p class="mt-5 font-display font-semibold text-pm-ink group-hover:text-pm-red transition-colors">Details →</p>
        </a>

        <a href={link("/tech-social")} class="group block bg-pm-paper text-pm-ink border-[5px] border-pm-ink p-7 hover:bg-white transition-colors">
          <div class="flex items-start justify-between">
            <span class="font-mono text-xs font-semibold tracking-[0.18em] uppercase text-pm-purple">First Fridays · Monthly</span>
            <div class="w-8 h-8 opacity-80">
              <Geometric shape="plus" color="purple" />
            </div>
          </div>
          <h3 class="mt-3 font-display font-bold text-3xl tracking-tight leading-tight">Tech Social — speaker series</h3>
          <p class="mt-3 text-pm-ink/75 leading-relaxed">A guest speaker, free dinner, casual hangout for the maker community. Bring the kids.</p>
          <p class="mt-5 font-display font-semibold text-pm-ink group-hover:text-pm-red transition-colors">Upcoming speakers →</p>
        </a>
      </div>
    </div>
  </section>

  <!-- WHY WE MAKE — purple Makey band -->
  <section class="relative bg-pm-purple text-white overflow-hidden">
    <!-- Decorative shapes -->
    <div class="absolute top-12 right-8 w-32 h-32 opacity-30">
      <Geometric shape="square-grid" color="cream" />
    </div>
    <div class="absolute bottom-8 left-1/3 w-24 h-24 opacity-25">
      <Geometric shape="rings" color="cream" />
    </div>

    <div class="relative mx-auto max-w-7xl px-6 py-20 md:py-24 grid md:grid-cols-12 gap-10 items-center">
      <div class="md:col-span-5 flex items-center justify-center md:justify-start">
        <div class="relative">
          <div class="absolute -top-4 -left-4 w-16 h-16 z-10">
            <Geometric shape="circle" color="cyan" />
          </div>
          <div class="absolute -bottom-4 -right-4 w-12 h-12 z-10">
            <Geometric shape="plus" color="red" />
          </div>
          <div class="bg-pm-purple-deep p-8 border-[5px] border-pm-cream">
            <img src={`${base}/img/brand/makey.png`} alt="Makey, the Piedmont Makers mascot" class="w-56 md:w-64 h-auto" />
          </div>
        </div>
      </div>
      <div class="md:col-span-7">
        <div class="flex items-center gap-3 mb-6">
          <span class="font-mono text-xs font-semibold tracking-[0.18em] uppercase">Section 03 / Why we make</span>
          <div class="h-px w-16 bg-white/40"></div>
        </div>
        <h2 class="font-display font-bold text-4xl md:text-5xl tracking-tight leading-[1.04]">
          Because every kid in Piedmont should get to build something they&apos;re proud of.
        </h2>
        <p class="mt-7 text-lg text-white/85 leading-relaxed max-w-2xl">
          We&apos;re a 501(c)(3) run entirely by parents and volunteers. We don&apos;t charge admission to most of what we do. We give $25,000+ in STEAM grants to local teachers every year. We run robotics teams, a community engineering lab, and a school maker faire that&apos;s now in its 12th year.
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a href={link("/about")} class="inline-flex items-center gap-2 bg-pm-cream text-pm-ink font-display font-semibold px-6 py-3 hover:bg-white transition-colors">
            Meet the board →
          </a>
          <a href={link("/community")} class="inline-flex items-center gap-2 border-[3px] border-pm-cream text-pm-cream font-display font-semibold px-6 py-[10px] hover:bg-pm-cream hover:text-pm-purple transition-colors">
            Volunteer with us
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW TO HELP — three sharp color blocks -->
  <section class="mx-auto max-w-7xl px-6 py-20 md:py-24">
    <div class="flex items-center gap-3 mb-6">
      <span class="font-mono text-xs font-semibold tracking-[0.18em] uppercase text-pm-ink/70">Section 04 / Get involved</span>
      <div class="h-px w-16 bg-pm-ink/30"></div>
    </div>
    <h2 class="font-display font-bold text-4xl md:text-6xl tracking-tight leading-[0.95] max-w-2xl">
      Three ways to keep this going.
    </h2>

    <div class="mt-12 grid md:grid-cols-3 gap-0 border-[5px] border-pm-ink">
      <a href="https://donate.piedmontmakers.org" class="group block bg-pm-ink text-pm-cream p-8 md:p-10 md:border-r-[5px] border-pm-ink hover:bg-pm-ink-soft transition-colors">
        <div class="flex items-start justify-between">
          <span class="font-mono text-xs font-semibold tracking-[0.18em] uppercase text-pm-red">01 / Donate</span>
          <div class="w-10 h-10">
            <Geometric shape="rings" color="red" />
          </div>
        </div>
        <h3 class="mt-6 font-display font-bold text-3xl md:text-4xl tracking-tight">Donate</h3>
        <p class="mt-3 text-pm-cream/80 leading-relaxed">Direct to programs. Square-processed. EIN 81-2725831. Tax-deductible.</p>
        <p class="mt-6 font-display font-semibold group-hover:text-pm-red transition-colors">donate.piedmontmakers.org →</p>
      </a>

      <a href={link("/community")} class="group block bg-pm-cyan text-white p-8 md:p-10 md:border-r-[5px] border-pm-ink hover:bg-pm-cyan-deep transition-colors">
        <div class="flex items-start justify-between">
          <span class="font-mono text-xs font-semibold tracking-[0.18em] uppercase">02 / Volunteer</span>
          <div class="w-10 h-10">
            <Geometric shape="plus" color="cream" />
          </div>
        </div>
        <h3 class="mt-6 font-display font-bold text-3xl md:text-4xl tracking-tight">Volunteer</h3>
        <p class="mt-3 text-white/85 leading-relaxed">Coach a team, mentor at Maker Faire, help with Tech Social. A few hours a month, real impact.</p>
        <p class="mt-6 font-display font-semibold group-hover:text-pm-ink transition-colors">See open roles →</p>
      </a>

      <a href="https://www.bonfire.com/piedmont-makers-t-shirt/" class="group block bg-pm-red text-white p-8 md:p-10 hover:bg-pm-red-deep transition-colors">
        <div class="flex items-start justify-between">
          <span class="font-mono text-xs font-semibold tracking-[0.18em] uppercase">03 / Merch</span>
          <div class="w-10 h-10">
            <Geometric shape="circle" color="cream" />
          </div>
        </div>
        <h3 class="mt-6 font-display font-bold text-3xl md:text-4xl tracking-tight">Buy a shirt</h3>
        <p class="mt-3 text-white/85 leading-relaxed">Makey, in full color, on quality cotton. Proceeds fund the programs.</p>
        <p class="mt-6 font-display font-semibold group-hover:text-pm-cream transition-colors">Shop on Bonfire →</p>
      </a>
    </div>

    <!-- A/B comparison link footer -->
    <div class="mt-16 pt-8 border-t border-pm-ink/15 flex items-center justify-between gap-4 flex-wrap">
      <span class="font-mono text-xs text-pm-ink/60 uppercase tracking-[0.18em]">You&apos;re viewing Option B · Bold modular</span>
      <a href={link("/")} class="font-display font-semibold text-pm-ink underline underline-offset-4 hover:text-pm-red">
        ← Switch to Option A (community workshop)
      </a>
    </div>
  </section>
</AltLayout>
