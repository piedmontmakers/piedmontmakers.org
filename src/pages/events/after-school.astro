---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Banner from "../../components/Banner.astro";
import Ribbon from "../../components/Ribbon.astro";
import PhotoCard from "../../components/PhotoCard.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (path: string) => `${base}${path}`;
---

<BaseLayout
  title="After-School Enrichment — Piedmont Makers"
  description="Hands-on after-school STEAM enrichment for elementary kids in PUSD: Tinker Toy Lab and Maker Invention Studio."
>
  <!-- Program paused for Fall 2026. Remove this banner (and restore the nav
       link + events hub card, see AGENTS.md) when the program returns. -->
  <section class="mx-auto max-w-7xl px-6 pt-10 md:pt-12">
    <Banner
      color="cyan"
      eyebrow="On pause"
      headline="After-school enrichment is paused for the 2026-27 school year."
      body="Subscribe to the newsletter and we'll tell you the moment sessions come back."
      ctaLabel="Get the newsletter"
      ctaHref="/#newsletter"
    />
  </section>

  <section class="mx-auto max-w-7xl px-6 pt-10 md:pt-12 pb-8">
    <a href={link("/events")} class="font-display font-semibold text-pm-ink hover:text-pm-red underline-offset-4 hover:underline">
      ← All events
    </a>
    <div class="mt-6">
      <Ribbon color="cyan">After-School Enrichment</Ribbon>
    </div>
    <h1 class="mt-6 font-display font-bold text-pm-ink text-5xl md:text-6xl tracking-tight leading-[0.98]">
      Hands-on STEAM, after the school day.
    </h1>
    <p class="mt-7 max-w-2xl text-lg md:text-xl text-pm-ink/75 leading-relaxed">
      Two after-school programs for elementary kids: Tinker Toy Lab (art and playful engineering, Grades 1–5) and Maker Invention Studio (electronics and coding, Grades 3–5). Piloted at Beach Elementary, where both sessions filled within minutes.
    </p>
  </section>

  <section class="mx-auto max-w-7xl px-6 py-12">
    <div class="grid md:grid-cols-2 gap-8">
      <article class="bg-pm-paper border-[3px] border-pm-ink p-8">
        <Ribbon color="cyan">Tinker Toy Lab</Ribbon>
        <p class="mt-4 font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55">Grades 1–5</p>
        <h2 class="mt-2 font-display font-bold text-2xl md:text-3xl tracking-tight leading-tight">
          Art, design, and playful engineering for kids who love to create.
        </h2>
        <p class="mt-4 text-pm-ink/80 leading-relaxed">
          Kids build instruments, giant cardboard costumes, flying contraptions, and other inventions. Designed to be accessible and engaging for kids who might not normally gravitate toward STEAM but love to create.
        </p>
      </article>

      <article class="bg-pm-paper border-[3px] border-pm-ink p-8">
        <Ribbon color="purple">Maker Invention Studio</Ribbon>
        <p class="mt-4 font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55">Grades 3–5</p>
        <h2 class="mt-2 font-display font-bold text-2xl md:text-3xl tracking-tight leading-tight">
          Science and engineering for kids ready to build things that work.
        </h2>
        <p class="mt-4 text-pm-ink/80 leading-relaxed">
          Students experiment with mechanics, electronics, and coding using the micro:bit platform. The focus is on problem-solving, expanding maker skills, and learning to collaborate through hands-on engineering challenges.
        </p>
      </article>
    </div>
  </section>

  <section class="bg-pm-cream-2/60 mt-12">
    <div class="mx-auto max-w-7xl px-6 py-16">
      <Ribbon color="red">Bring it to your school</Ribbon>
      <h2 class="mt-5 font-display font-bold text-3xl md:text-4xl tracking-tight leading-tight max-w-3xl">
        Coming to more PUSD elementary schools.
      </h2>
      <p class="mt-5 max-w-2xl text-lg text-pm-ink/85 leading-relaxed">
        Both pilot sessions at Beach Elementary filled within minutes of registration opening, so we&apos;re working with PUSD to expand. If you&apos;re a school administrator or PTA member interested in hosting a program, email <a href="mailto:hello@piedmontmakers.org" class="font-display font-semibold underline underline-offset-4 decoration-pm-red hover:text-pm-red">hello@piedmontmakers.org</a>.
      </p>
      <p class="mt-4 max-w-2xl text-pm-ink/75 leading-relaxed">
        Registration windows and waitlist signups land in <a href={link("/#newsletter")} class="font-display font-semibold underline underline-offset-4 decoration-pm-red hover:text-pm-red">the newsletter</a>. Last time, both sessions sold out within minutes, so subscribing is the only way to catch the opening.
      </p>
    </div>
  </section>
</BaseLayout>
