const totalExhibits = sections.reduce((sum, s) => sum + s.items.length, 0);
---

<BaseLayout
  title="Meet the Makers — School Maker Faire — Piedmont Makers"
  description="Every project from the 11th Annual Piedmont School Maker Faire (May 18, 2025) — 80+ exhibits across hands-on stations, school projects, robotics teams, and community partners."
>
  <section class="mx-auto max-w-7xl px-6 pt-16 md:pt-20 pb-8">
    <a href={link("/events/maker-faire")} class="font-display font-semibold text-pm-ink hover:text-pm-red underline-offset-4 hover:underline">
      ← School Maker Faire
    </a>
    <div class="mt-6">
      <Ribbon color="cyan">Meet the Makers · 11th Annual · 2025</Ribbon>
    </div>
    <h1 class="mt-6 font-display font-bold text-pm-ink text-5xl md:text-6xl tracking-tight leading-[0.98]">
      80+ projects.<br />200+ student makers.
    </h1>
    <p class="mt-7 max-w-3xl text-lg md:text-xl text-pm-ink/75 leading-relaxed">
      The 11th annual Piedmont School Maker Faire showcased more than 80 projects featuring the STEAM creativity, passion, and effort of over 200 makers in our community. Here&apos;s the full lineup from May 18, 2025 — kept for posterity, and as inspiration for whatever comes to the 13th annual in 2027.
    </p>
  </section>

  <section class="mx-auto max-w-7xl px-6 pb-20">
    <p class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55 mb-6 text-right">
      {totalExhibits} exhibits across {sections.length} sections
    </p>

    <div class="space-y-12">
      {sections.map((s) => (
        <div>
          <h2 class="font-display font-bold text-2xl md:text-3xl tracking-tight border-b-2 border-pm-ink pb-3">
            {s.title}
          </h2>
          <ul class="mt-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-2 text-pm-ink/85">
            {s.items.map((item) => (
              <li class="text-sm md:text-base leading-snug">· {item}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-pm-cream-2/60 mt-8">
    <div class="mx-auto max-w-7xl px-6 py-16">
      <Ribbon color="purple">Inspired?</Ribbon>
      <h2 class="mt-5 font-display font-bold text-3xl md:text-4xl tracking-tight leading-tight max-w-2xl">
        Bring your own project to the 13th annual.
      </h2>
      <p class="mt-5 max-w-2xl text-lg text-pm-ink/85 leading-relaxed">
        Exhibit signups for the next faire open in spring 2027. In the meantime, scroll through the <a href={link("/events/maker-faire/project-ideas")} class="font-display font-semibold underline underline-offset-4 decoration-pm-red hover:text-pm-red">A–Z project ideas</a> for inspiration, and <a href={link("/#newsletter")} class="font-display font-semibold underline underline-offset-4 decoration-pm-red hover:text-pm-red">subscribe to the newsletter</a> so we can tell you when the signup form opens.
      </p>
    </div>
  </section>
</BaseLayout>
