---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Ribbon from "../../../components/Ribbon.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (path: string) => `${base}${path}`;

