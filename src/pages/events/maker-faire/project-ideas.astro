---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Ribbon from "../../../components/Ribbon.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (path: string) => `${base}${path}`;

// A–Z brainstorm list migrated from the Wix /maker-faire-project-ideas page.
// Intentionally idiosyncratic — there's some "Z is for Zombie Zoo" energy.
// Kept as inspiration for prospective Maker Faire exhibitors.
const alphabet = [
  { letter: "A", items: ["Animation", "Airplanes", "Apple Juice", "AI"] },
  { letter: "B", items: ["Books", "Biotech", "Boats", "Bike Repair"] },
  { letter: "C", items: ["Costumes", "Clocks", "Catapults", "Circuits", "Cardboard Crafts"] },
  { letter: "D", items: ["Design", "Dragons", "DIY", "Drones"] },
  { letter: "E", items: ["E-Textiles", "Eccentric Projects"] },
  { letter: "F", items: ["Face Paint", "Felting", "Fancy Foods"] },
  { letter: "G", items: ["Games", "Golf", "Green Tech"] },
  { letter: "H", items: ["Hovercraft", "Hourglass", "How To Fix and Take Apart"] },
  { letter: "I", items: ["Interactive Ice Sculptures", "Invisible Ink"] },
  { letter: "J", items: ["Jewelry", "JunkBots"] },
  { letter: "K", items: ["Knitting", "Kites"] },
  { letter: "L", items: ["Leathercraft", "Lace", "LEDs", "LEGO"] },
  { letter: "M", items: ["Motors", "Mobiles", "Magic", "Musical Instruments and Performances"] },
  { letter: "N", items: ["Needlepoint", "Nanotechnology"] },
  { letter: "O", items: ["Origami", "Oobleck", "Ovens"] },
  { letter: "P", items: ["Puppets", "Pottery", "Perfume", "Painting"] },
  { letter: "Q", items: ["Quilting", "Quicksand"] },
  { letter: "R", items: ["Robots", "Rockets"] },
  { letter: "S", items: ["Slime", "Sculpture", "Science / STEAM Expo Projects"] },
  { letter: "T", items: ["Toys", "Tiny Houses", "Telescopes", "Tools"] },
  { letter: "U", items: ["Ukuleles", "Unusual Machines"] },
  { letter: "V", items: ["Virtual Reality", "Volcanoes", "Vintage Vehicles"] },
  { letter: "W", items: ["Woodworking", "Welding", "Wearables", "Water Filtration"] },
  { letter: "X", items: ["Xylography", "Xiphias X-Rays"] },
  { letter: "Y", items: ["Yodeling", "Yarn"] },
  { letter: "Z", items: ["Zombie Zoo", "Zymometer"] },
];
---

<BaseLayout
  title="Project Ideas — School Maker Faire — Piedmont Makers"
  description="An A–Z brainstorm for prospective Piedmont School Maker Faire exhibitors. From Animation to Zymometer, with a Zombie Zoo in between."
>
  <section class="mx-auto max-w-7xl px-6 pt-16 md:pt-20 pb-8">
    <a href={link("/events/maker-faire")} class="font-display font-semibold text-pm-ink hover:text-pm-red underline-offset-4 hover:underline">
      ← School Maker Faire
    </a>
    <div class="mt-6">
      <Ribbon color="purple">Project ideas · A to Z</Ribbon>
    </div>
    <h1 class="mt-6 font-display font-bold text-pm-ink text-5xl md:text-6xl tracking-tight leading-[0.98]">
      Interested in exhibiting?<br />Start here.
    </h1>
    <p class="mt-7 max-w-3xl text-lg md:text-xl text-pm-ink/75 leading-relaxed">
      Browse this idiosyncratic A–Z for inspiration. Search online for any of these and you&apos;ll find guides, kits, and videos. Bring a project that&apos;s complete, a work in progress, or a hands-on activity for other makers to build, test, or explore.
    </p>
    <p class="mt-4 max-w-3xl text-pm-ink/65 leading-relaxed">
      The faire welcomes K-12 students, parents, teachers, and community members. All skill levels. The wilder, the better.
    </p>
  </section>

  <section class="mx-auto max-w-7xl px-6 pb-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-6 gap-y-8">
      {alphabet.map((entry) => (
        <div class="border-l-4 border-pm-cyan pl-5">
          <p class="font-display font-bold text-3xl md:text-4xl text-pm-ink leading-none">{entry.letter}</p>
          <ul class="mt-3 space-y-1 text-pm-ink/85">
            {entry.items.map((item) => (
              <li class="text-sm md:text-base">· {item}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-pm-cream-2/60 mt-8">
    <div class="mx-auto max-w-7xl px-6 py-16">
      <Ribbon color="cyan">See what others have built</Ribbon>
      <h2 class="mt-5 font-display font-bold text-3xl md:text-4xl tracking-tight leading-tight max-w-2xl">
        The 2025 lineup is a great place for inspiration.
      </h2>
      <p class="mt-5 max-w-2xl text-lg text-pm-ink/85 leading-relaxed">
        80+ projects across hands-on stations, every PUSD school, robotics, music, and community partners.
      </p>
      <a href={link("/events/maker-faire/meet-the-makers")} class="mt-6 inline-flex items-center gap-2 font-display font-semibold text-pm-ink underline underline-offset-4 decoration-pm-red hover:text-pm-red">
        Meet the 2025 makers →
      </a>
    </div>
  </section>
</BaseLayout>
