---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Ribbon from "../../components/Ribbon.astro";
import PhotoCard from "../../components/PhotoCard.astro";
import FAQ from "../../components/FAQ.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (path: string) => `${base}${path}`;

const faqItems = [
  {
    q: "Is admission really free?",
    a: "Yes. Admission is free. We just ask people to register ahead so we have a rough headcount for the day.",
  },
  {
    q: "What ages is the faire for?",
    a: "All ages. Most exhibits come from K-12 students in PUSD, but the audience is the whole community. Kids, parents, grandparents, neighbors, anyone curious about what local students are making.",
  },
  {
    q: "I don't live or go to school in Piedmont. Can I still exhibit and attend?",
    a: "Yes, please come. The faire is open to the whole East Bay. Exhibitors from outside Piedmont are very welcome; we just love a good project.",
  },
  {
    q: "Can my kid (or my class) exhibit?",
    a: "Yes. The exhibit signup form is open in the spring. Any project type works: drones, cosplay, puppets, kites, VR, LEGO creations, music, ceramics, anything you made and want to talk about.",
  },
  {
    q: "How do I volunteer?",
    a: "Setup, cleanup, logistics, helping exhibitors during the day. The volunteer signup form opens in the spring. Most volunteer shifts are short (1-2 hours) and you can pick what fits your day.",
  },
  {
    q: "Where is parking?",
    a: "Piedmont High School has limited parking. We recommend walking or biking if you can; otherwise plan to arrive a little early and find street parking in the surrounding neighborhood.",
  },
  {
    q: "Is it indoors or outdoors?",
    a: "Mostly outdoors. Exhibits, demos, and food spread across the high school courtyards and outdoor spaces; a smaller portion sits inside the main building.",
  },
];
---

<BaseLayout
  title="School Maker Faire — Piedmont Makers"
  description="The Piedmont School Maker Faire is our biggest community event. Hundreds of student-built projects, free admission, all ages. Next: May 2027."
>
  <!-- Hero — text + YouTube embed -->
  <section class="mx-auto max-w-7xl px-6 pt-16 md:pt-20 pb-8">
    <a href={link("/events")} class="font-display font-semibold text-pm-ink hover:text-pm-red underline-offset-4 hover:underline">
      ← All events
    </a>
    <div class="mt-6 grid md:grid-cols-12 gap-10 md:gap-12 items-center">
      <div class="md:col-span-6">
        <Ribbon color="red">School Maker Faire</Ribbon>
        <h1 class="mt-6 font-display font-bold text-pm-ink text-5xl md:text-6xl lg:text-7xl tracking-tight leading-[0.95]">
          A whole community day of kid-made everything.
        </h1>
        <p class="mt-7 text-lg md:text-xl text-pm-ink/75 leading-relaxed">
          One day, hundreds of kid-built projects, free admission. K-12 STEAM, for the East Bay community and anyone curious.
        </p>
      </div>
      <div class="md:col-span-6">
        <div class="aspect-video overflow-hidden rounded-3xl border-[3px] border-pm-ink shadow-[var(--shadow-card)]">
          <iframe
            src="https://www.youtube-nocookie.com/embed/AFnC-dBw2CY?rel=0"
            title="Piedmont School Maker Faire"
            loading="lazy"
            allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen
            class="w-full h-full"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- 12th Annual recap -->
  <section class="mx-auto max-w-7xl px-6 py-12">
    <div class="grid md:grid-cols-12 gap-8">
      <div class="md:col-span-7 bg-pm-cream-2/70 border-[3px] border-pm-ink p-7 md:p-9">
        <p class="font-marker text-2xl text-pm-purple">just wrapped —</p>
        <h2 class="mt-2 font-display font-bold text-3xl md:text-4xl tracking-tight leading-tight">
          12th Annual · May 17, 2026
        </h2>
        <p class="mt-4 text-pm-ink/85 leading-relaxed">
          Thanks to everyone who came, exhibited, and volunteered. Recap details and 2026 photos are coming soon. The next Maker Faire is planned for May 2027. <a href={link("/#newsletter")} class="font-display font-semibold underline underline-offset-4 decoration-pm-red hover:text-pm-red">Subscribe to the newsletter</a> for the date.
        </p>
      </div>
      <div class="md:col-span-5 space-y-3">
        <div class="bg-pm-paper border-[3px] border-pm-ink p-5">
          <p class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55">Were you part of it?</p>
          <p class="mt-1 font-display font-bold text-xl md:text-2xl tracking-tight leading-tight">Photos &amp; recap</p>
          <p class="mt-2 text-sm text-pm-ink/65 leading-relaxed">We&apos;ll post a recap blog and event photos as soon as they&apos;re organized. Watch the blog.</p>
          <a href={link("/blog")} class="mt-3 inline-block font-display font-semibold text-pm-ink underline underline-offset-4 decoration-pm-red hover:text-pm-red">Read the blog →</a>
        </div>
        <div class="bg-pm-paper border-[3px] border-pm-ink p-5">
          <p class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55">Stay in the loop</p>
          <p class="mt-1 font-display font-bold text-xl md:text-2xl tracking-tight leading-tight">May 2027 date drops in the newsletter</p>
          <a href={link("/#newsletter")} class="mt-3 inline-block font-display font-semibold text-pm-ink underline underline-offset-4 decoration-pm-red hover:text-pm-red">Subscribe →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Get inspired / Make / Explore sub-pages -->
  <section class="mx-auto max-w-7xl px-6 py-12">
    <Ribbon color="cyan">Browse and get inspired</Ribbon>
    <h2 class="mt-5 font-display font-bold text-3xl md:text-4xl tracking-tight leading-tight">
      The Maker Faire archive.
    </h2>
    <p class="mt-4 max-w-2xl text-pm-ink/75 leading-relaxed">
      Two pages for prospective makers, whether you want to see what other kids built last year or you&apos;re trying to come up with your own project.
    </p>

    <div class="mt-8 grid md:grid-cols-2 gap-6">
      <a href={link("/events/maker-faire/meet-the-makers")} class="group block bg-pm-paper border-[3px] border-pm-ink p-7 hover:bg-white transition-colors">
        <p class="font-display text-xs uppercase tracking-[0.18em] text-pm-cyan-deep">11th Annual · 2025</p>
        <h3 class="mt-2 font-display font-bold text-2xl md:text-[1.7rem] tracking-tight leading-tight">Meet the makers →</h3>
        <p class="mt-3 text-pm-ink/75 leading-relaxed">The full lineup of 80+ projects and 200+ student makers from the 2025 faire. Browse by section: hands-on stations, every PUSD school, robotics, music, and community partners.</p>
      </a>
      <a href={link("/events/maker-faire/project-ideas")} class="group block bg-pm-paper border-[3px] border-pm-ink p-7 hover:bg-white transition-colors">
        <p class="font-display text-xs uppercase tracking-[0.18em] text-pm-purple">A–Z brainstorm</p>
        <h3 class="mt-2 font-display font-bold text-2xl md:text-[1.7rem] tracking-tight leading-tight">Project ideas →</h3>
        <p class="mt-3 text-pm-ink/75 leading-relaxed">From Animation to Zymometer (with Zombie Zoo somewhere in the middle). Stuck on what to bring? Start with the letter that interests you and follow it.</p>
      </a>
    </div>
  </section>

  <!-- Returning Spring 2027 — dormant CTAs preserved for next year -->
  <section class="mx-auto max-w-7xl px-6 py-12">
    <Ribbon color="ink">Spring 2027</Ribbon>
    <h2 class="mt-5 font-display font-bold text-3xl md:text-4xl tracking-tight leading-tight">
      Want to volunteer or exhibit next year?
    </h2>
    <p class="mt-4 max-w-2xl text-pm-ink/75 leading-relaxed">
      The 12th annual just wrapped on May 17, 2026. Sign-ups for the 13th annual open in spring 2027. The buttons below are placeholders for now. They&apos;ll wake up about six weeks before the next faire.
    </p>
    <div class="mt-6 grid md:grid-cols-3 gap-4">
      <!-- Tickets: when the next Eventbrite event is live, swap href + remove aria-disabled -->
      <span
        aria-disabled="true"
        class="block bg-pm-paper/60 border-2 border-dashed border-pm-ink/25 p-5 cursor-not-allowed"
      >
        <p class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/40">Returns spring 2027</p>
        <p class="mt-1 font-display font-bold text-xl text-pm-ink/55 tracking-tight">Free tickets</p>
        <p class="mt-2 text-sm text-pm-ink/45 leading-relaxed">Eventbrite registration. Admission is always free.</p>
      </span>
      <!-- Volunteer: re-enable the Grasshopper form for the next faire -->
      <span
        aria-disabled="true"
        class="block bg-pm-paper/60 border-2 border-dashed border-pm-ink/25 p-5 cursor-not-allowed"
      >
        <p class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/40">Returns spring 2027</p>
        <p class="mt-1 font-display font-bold text-xl text-pm-ink/55 tracking-tight">Volunteer</p>
        <p class="mt-2 text-sm text-pm-ink/45 leading-relaxed">Setup, cleanup, logistics, exhibit support. Short shifts, real impact.</p>
      </span>
      <!-- Exhibit: re-enable the Google Form submission for the next faire -->
      <span
        aria-disabled="true"
        class="block bg-pm-paper/60 border-2 border-dashed border-pm-ink/25 p-5 cursor-not-allowed"
      >
        <p class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/40">Returns spring 2027</p>
        <p class="mt-1 font-display font-bold text-xl text-pm-ink/55 tracking-tight">Sign up to exhibit</p>
        <p class="mt-2 text-sm text-pm-ink/45 leading-relaxed">All project types: drones, cosplay, puppets, kites, VR, LEGO, music. Show off what you made.</p>
      </span>
    </div>
    <p class="mt-6 text-sm text-pm-ink/55">
      Subscribers to <a href={link("/#newsletter")} class="font-display font-semibold underline underline-offset-4 decoration-pm-red hover:text-pm-red">the newsletter</a> get the 2027 date and signup links first.
    </p>
    {/*
      Reference URLs for re-enabling in spring 2027:
      - Tickets:    https://www.eventbrite.com/e/12th-annual-piedmont-school-maker-faire-tickets-1987744231505 (replace event ID for 13th annual)
      - Volunteer:  https://grasshoppersignup.com/s/qo1qew (Grasshopper form — confirm whether re-used or new each year)
      - Exhibit:    https://docs.google.com/forms/d/e/1FAIpQLSe_oL4UXCNJnETrYTlnWwD-Vg71smX2i-kzt6tV9LlDowgczA/viewform (Google Form)
    */}
  </section>

  <!-- 11th Annual recap (May 18, 2025) -->
  <section class="mx-auto max-w-7xl px-6 py-12">
    <Ribbon color="cyan">11th Annual recap · May 18, 2025</Ribbon>
    <div class="mt-6 grid md:grid-cols-12 gap-8">
      <div class="md:col-span-7">
        <h2 class="font-display font-bold text-3xl md:text-4xl tracking-tight leading-tight">
          1,000+ visitors. Record 80+ student makers.
        </h2>
        <p class="mt-5 text-lg text-pm-ink/75 leading-relaxed">
          Sunday May 18, 2025, the 11th annual faire drew over <strong>1,000 community members</strong> to the Piedmont High School campus. A record <strong>80+ student exhibitors</strong> showed what they made all year. Browse the <a href={link("/events/maker-faire/meet-the-makers")} class="font-display font-semibold underline underline-offset-4 decoration-pm-red hover:text-pm-red">full lineup</a>.
        </p>
        <p class="mt-4 text-pm-ink/75 leading-relaxed">
          Kids built vehicles for derby races. They made slime, bath fizzies, and beaded crafts. They launched air rockets and used robots to play mini golf. Teacher grantees shared classroom projects, including student-made electric guitars, light-up plushies, and (yes) actual heart dissections.
        </p>
        <p class="mt-4 text-pm-ink/75 leading-relaxed">
          Community partners brought sustainability into focus: <strong>The Nimble Repair</strong> ran fix-it stations. <strong>The Denim Project</strong> demonstrated textile reuse. <strong>STEAM Toy Swap</strong> gave old toys new homes.
        </p>
      </div>
      <div class="md:col-span-5">
        <PhotoCard
          caption="2025 Maker Faire LEGO play table"
          color="cyan"
          tilt="right"
          aspect="landscape"
          src="/img/programs/maker-faire.jpg"
          alt="Children and parents gathered around a large outdoor LEGO play table at the Piedmont School Maker Faire."
        />
      </div>
    </div>
  </section>

  <!-- Stats band -->
  <section class="bg-pm-ink text-pm-cream">
    <div class="mx-auto max-w-7xl px-6 py-12">
      <ul class="grid grid-cols-2 md:grid-cols-4 gap-y-8 gap-x-6 md:divide-x divide-pm-cream/15">
        <li class="text-center md:px-6">
          <p class="font-display font-bold text-3xl md:text-4xl text-pm-red leading-none">1,000+</p>
          <p class="mt-2 text-sm text-pm-cream/80">community visitors in 2025</p>
        </li>
        <li class="text-center md:px-6">
          <p class="font-display font-bold text-3xl md:text-4xl text-pm-cyan leading-none">80+</p>
          <p class="mt-2 text-sm text-pm-cream/80">student-exhibitor tables</p>
        </li>
        <li class="text-center md:px-6">
          <p class="font-display font-bold text-3xl md:text-4xl text-pm-purple leading-none">12</p>
          <p class="mt-2 text-sm text-pm-cream/80">years and counting</p>
        </li>
        <li class="text-center md:px-6">
          <p class="font-display font-bold text-3xl md:text-4xl text-pm-cream leading-none">$0</p>
          <p class="mt-2 text-sm text-pm-cream/80">admission · always free</p>
        </li>
      </ul>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mx-auto max-w-7xl px-6 py-12">
    <Ribbon color="purple">FAQ</Ribbon>
    <h2 class="mt-5 font-display font-bold text-3xl md:text-4xl tracking-tight">
      Common questions.
    </h2>
    <div class="mt-8">
      <FAQ items={faqItems} />
    </div>
    <p class="mt-6 text-pm-ink/75">
      Still have something specific? Email <a href="mailto:hello@piedmontmakers.org" class="font-display font-semibold underline underline-offset-4 decoration-pm-red hover:text-pm-red">hello@piedmontmakers.org</a>.
    </p>
  </section>

  <!-- Past faires footer -->
  <section class="mx-auto max-w-7xl px-6 py-16">
    <div class="rounded-3xl bg-pm-ink text-pm-cream p-10 md:p-14">
      <Ribbon color="cyan">12 years and counting</Ribbon>
      <h2 class="mt-5 font-display font-bold text-3xl md:text-4xl tracking-tight">
        The faire has happened every spring since 2014.
      </h2>
      <p class="mt-3 max-w-2xl text-pm-cream/75 leading-relaxed">
        Full event history lives on the <a href={link("/calendar")} class="font-display font-semibold underline underline-offset-4 decoration-pm-red hover:text-pm-red">events calendar</a>. Scroll down to "Past events."
      </p>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    // Track clicks on newsletter subscribe links on this page
    document.querySelectorAll('a[href*="#newsletter"]').forEach(function (el) {
      el.addEventListener('click', function () {
        window.posthog?.capture('maker_faire_newsletter_clicked');
      });
    });
  });
</script>
