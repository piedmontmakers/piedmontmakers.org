---
import BaseLayout from "../layouts/BaseLayout.astro";
import Ribbon from "../components/Ribbon.astro";
import PhotoCard from "../components/PhotoCard.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (path: string) => `${base}${path}`;

// Major sponsors of 10th Street (the youth robotics practice field).
// Per Ben's policy, we don't publish 3rd-party donor amounts — listing
// names + the nature of their contribution only.
const tenthStreetSponsors = [
  { name: "PG&E Corporation Foundation", note: "Grant" },
  { name: "KLA Foundation", note: "Grant" },
  { name: "Autodesk", note: "CNC Router · in-kind" },
];

// Engineering Lab donors. Pulled from the existing piedmontmakers.org/engineering-lab
// page, preserving the two tiers and the order names appear in.
const labMajorDonors = [
  "Anonymous Donor",
  "The Potter-Lambert Family",
  "The Aldridge Family",
  "The Chakravartula Holt Family",
  "The Chan Family",
  "The Chu Family",
  "Melissa, Kevin, Elle, and Mara Clark",
  "The Cooper Family",
  "The Gourjian Sarafian Family",
  "The Hupp Family",
  "The Kemp Khouri Family",
  "The Leong Balasingham Family",
  "The Ragones Family",
  "The Saperstein Family",
  "The Schleuning Family",
  "The Seiden Family",
  "The Shields Family",
  "The Skidmore Sanford Family",
  "The von Metzsch Family",
  "The Wallway Family",
  "The Welch Family",
  "The Wiesbrock Family",
  "Julia Zhen",
  "The Zietlow Family",
  "Piedmont Makers",
  "Hypercube Robotics FTC 14341",
  "Google",
  "Salesforce Foundation",
  "The Walt Disney Company",
];

const labDonors = [
  "Ken Khouri",
  "Varian",
  "Mike Cvet",
  "The Behrens Ware Family",
  "Tom Joseph",
  "Natalia Duxbury",
  "The Lavin Family",
  "The Grochowski Yan Family",
  "Olja Dimitrijevic",
  "The Wolff Family",
  "The Smith Barber Family",
  "The Brahma Family",
  "The Heafey Family",
  "The Dickinson Family",
  "Andrew Schultz",
  "The Lin Schuetz Family",
  "The Hart Family",
  "Geoffrey Castronovo",
  "Laura Zuckerman",
  "The Posamentier Family",
  "The Paul Family",
  "The Hill Family",
  "The Sharafi Family",
  "Mary Wells",
  "The Walters Muthig Family",
  "Margaret Bridges",
  "The Riordan Family",
  "Jon Schleuning",
  "Jennifer Poole",
  "Laura Murphy",
  "Chris Kibarian",
];

// Major donors render in full by default; the regular Donors list is
// tucked behind a "See all" disclosure to keep the panel scannable.
const additionalCount = labDonors.length;
---

<BaseLayout
  title="Facilities — Piedmont Makers"
  description="Two community spaces: the 10th Street youth robotics practice field and the Mary G. Ross Engineering Lab at Piedmont High School."
>
  <!-- Hero -->
  <section class="mx-auto max-w-7xl px-6 pt-16 md:pt-20 pb-12">
    <Ribbon color="purple">Facilities</Ribbon>
    <h1 class="mt-6 font-display font-bold text-pm-ink text-5xl md:text-6xl tracking-tight leading-[0.98]">
      Two spaces where kids build, drive, and break things.
    </h1>
    <p class="mt-6 max-w-2xl text-lg md:text-xl text-pm-ink/75 leading-relaxed">
      The 10th Street practice field is the home base for FRC Team 8033 and a working lab for FTC teams. The Mary G. Ross Engineering Lab at Piedmont High School is the community engineering classroom, where robotics open houses, after-school programs, and Build Like a Girl sessions happen.
    </p>
  </section>

  <!-- 10TH STREET (now first — it's our most active practice space) -->
  <section id="tenth-street" class="mx-auto max-w-7xl px-6 py-16 scroll-mt-20">
    <div class="grid md:grid-cols-12 gap-10">
      <div class="md:col-span-5">
        <PhotoCard
          caption="The 10th Street practice field during an FRC build-season session"
          color="cyan"
          tilt="left"
          aspect="landscape"
          src="/img/facilities/10th-street.jpg"
          alt="Overhead view of the 10th Street practice field — a regulation-size FRC competition area with hundreds of yellow game pieces scattered across the floor, robots on the field, and the team and spectators around the edges."
        />
      </div>
      <div class="md:col-span-7">
        <Ribbon color="cyan">10th Street</Ribbon>
        <h2 class="mt-5 font-display font-bold text-4xl md:text-5xl tracking-tight leading-tight">
          The only community-accessible full-size FRC field in the Bay Area.
        </h2>
        <p class="mt-3 font-display text-sm uppercase tracking-[0.18em] text-pm-ink/55">Built and operated by Highlander Robotics 8033</p>
        <p class="mt-5 text-lg text-pm-ink/85 leading-relaxed">
          A regulation-size FIRST Robotics Competition field inside a warehouse-style space in Oakland. This space is primarily managed by Team 8033 and shared by youth robotics teams across the region.
        </p>
        <p class="mt-4 text-pm-ink/75 leading-relaxed">
          In 2025, Team 8033 piloted the concept at <em>The Loom</em>, a temporary 10,000 sq ft facility nearby, to prove that a community-accessible full-size FRC field would actually get used. It did! Teams that used to drive to East Palo Alto for full-field practice could now practice close to home.
        </p>
        <p class="mt-4 text-pm-ink/75 leading-relaxed">
          As fiscal sponsor, Piedmont Makers signed a multi-year lease on the space to maintain the much-needed shared regional infrastructure. Highlander Robotics students and mentors continue to operate the facility. In our first 6 months, 32 teams across FRC, FTC, and LEGO League logged 1,300+ practice hours and 1,273 check-ins, with 26 FRC teams scheduled into the field rotation.
        </p>
        <p class="mt-4 text-pm-ink/75 leading-relaxed">
          Build benches, tooling, a regulation field, and enough open floor for robots to drive around. Active members and visitors check in on arrival, and all visitors sign a one-time waiver before entering the build floor.
        </p>

        <dl class="mt-6 grid grid-cols-2 gap-x-6 gap-y-3 text-sm">
          <div>
            <dt class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55">Use</dt>
            <dd class="mt-0.5 font-semibold">Youth robotics practice + build</dd>
          </div>
          <div>
            <dt class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55">Address</dt>
            <dd class="mt-0.5 font-semibold">
              <a
                href="https://www.google.com/maps/search/?api=1&query=3100+East+10th+Street+Oakland+CA"
                target="_blank"
                rel="noopener noreferrer"
                class="underline underline-offset-4 decoration-pm-ink/30 hover:decoration-pm-red hover:text-pm-red transition-colors"
              >3100 East 10th Street<br />Oakland, CA</a>
            </dd>
          </div>
          <div>
            <dt class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55">Hours</dt>
            <dd class="mt-0.5 text-pm-ink/65 italic">During practice &amp; build season</dd>
          </div>
        </dl>

        <!-- Small Google Maps embed. Keyless ?output=embed URL, lazy-loaded
             so it doesn't block the page render. -->
        <iframe
          src="https://www.google.com/maps?q=3100+East+10th+Street+Oakland+CA&output=embed"
          title="Map: 3100 East 10th Street, Oakland"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          class="mt-6 w-full h-44 md:h-48 rounded-lg border-2 border-pm-ink/15"
        ></iframe>

        <!-- Three utility links for visitors. Outlined-pill style so they
             read as secondary actions; the ribbon shape is reserved for
             primary brand CTAs (Register, Donate). Order = onboarding flow:
             read the guidelines → sign the waiver once → check in each visit. -->
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="https://docs.google.com/document/d/1RFGhuBCfTaJu7H9k6fkn8T7z_Qch0iOkI7fRHVVGftM/edit?tab=t.zggakcezu7da"
            class="inline-flex items-center gap-2 rounded-full border-2 border-pm-ink px-5 py-2.5 font-display font-semibold text-pm-ink hover:bg-pm-ink hover:text-pm-cream transition-colors"
          >
            Practice Field Guidelines →
          </a>
          <a
            href="https://docs.google.com/forms/d/e/1FAIpQLSf1DZCi5av126Bf1tOIFiZaiDv-Gjy7dDEePpT9YFo4dWNKPA/viewform"
            class="inline-flex items-center gap-2 rounded-full border-2 border-pm-ink px-5 py-2.5 font-display font-semibold text-pm-ink hover:bg-pm-ink hover:text-pm-cream transition-colors"
          >
            Sign the waiver →
          </a>
          <a
            href="https://script.google.com/a/macros/piedmontmakers.org/s/AKfycbyvQwtTkmCk_P9k3dd3CmrjXh-zDBHaTt93uSC2swZIZbzhNFx8PNKuXhBnufjAUqLheA/exec"
            class="inline-flex items-center gap-2 rounded-full border-2 border-pm-ink px-5 py-2.5 font-display font-semibold text-pm-ink hover:bg-pm-ink hover:text-pm-cream transition-colors"
          >
            Check-in form →
          </a>
        </div>
      </div>
    </div>

    <!-- 10th Street stats — credits 8033's role explicitly -->
    <div class="mt-10 bg-pm-ink text-pm-cream p-8 md:p-10">
      <p class="font-display text-xs uppercase tracking-[0.18em] text-pm-cream/70 text-center">In our first 6 months</p>
      <div class="mt-6 grid grid-cols-2 md:grid-cols-4 gap-y-6 gap-x-6">
        <div class="text-center md:px-2">
          <p class="font-display font-bold text-3xl md:text-4xl text-pm-cyan leading-none">32</p>
          <p class="mt-2 text-xs md:text-sm text-pm-cream/80">teams across FRC, FTC, and LEGO League</p>
        </div>
        <div class="text-center md:px-2">
          <p class="font-display font-bold text-3xl md:text-4xl text-pm-red leading-none">1,300+</p>
          <p class="mt-2 text-xs md:text-sm text-pm-cream/80">practice hours logged on the field</p>
        </div>
        <div class="text-center md:px-2">
          <p class="font-display font-bold text-3xl md:text-4xl text-pm-purple leading-none">1,273</p>
          <p class="mt-2 text-xs md:text-sm text-pm-cream/80">student, mentor, and visitor check-ins</p>
        </div>
        <div class="text-center md:px-2">
          <p class="font-display font-bold text-3xl md:text-4xl text-pm-cream leading-none">26</p>
          <p class="mt-2 text-xs md:text-sm text-pm-cream/80">FRC teams scheduled into the field rotation</p>
        </div>
      </div>
    </div>

    <!-- 10th Street sponsors -->
    <div class="mt-6 bg-pm-cream-2/60 border-l-4 border-pm-cyan p-6 md:p-8">
      <p class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55">Sponsors of 8033's 10th Street campaign</p>
      <ul class="mt-3 space-y-1.5">
        {tenthStreetSponsors.map((s) => (
          <li class="flex items-baseline justify-between gap-4 border-b border-pm-ink/10 pb-1.5 last:border-0">
            <span class="font-display font-semibold text-lg md:text-xl tracking-tight">{s.name}</span>
            <span class="font-display text-sm md:text-base text-pm-ink/65">{s.note}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ENGINEERING LAB (now below) -->
  <section id="engineering-lab" class="mx-auto max-w-7xl px-6 py-16 scroll-mt-20 border-t border-pm-ink/15">
    <div class="grid md:grid-cols-12 gap-10">
      <div class="md:col-span-7 md:order-1">
        <Ribbon color="purple">Engineering Lab</Ribbon>
        <h2 class="mt-5 font-display font-bold text-4xl md:text-5xl tracking-tight leading-tight">
          Where high schoolers build robots.
        </h2>
        <p class="mt-3 font-display text-sm uppercase tracking-[0.18em] text-pm-ink/55">The Mary G. Ross Engineering Lab</p>
        <p class="mt-5 text-lg text-pm-ink/85 leading-relaxed">
          The community engineering classroom at Piedmont High School. Home base for FTC robotics teams, after-school engineering programs, and the annual K–8 robotics open houses where prospective families see what robotics looks like up close.
        </p>
        <p class="mt-4 text-pm-ink/75 leading-relaxed">
          The space is named for Mary G. Ross, the first known Native American female engineer and a pioneer at Lockheed's Skunk Works. Three of the lab's rooms honor pioneering women in STEAM, with stipple portraits dedicated at the ribbon-cutting ceremony by members of Highlander Robotics 8033.
        </p>

        <dl class="mt-6 grid grid-cols-2 gap-x-6 gap-y-3 text-sm">
          <div>
            <dt class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55">Address</dt>
            <dd class="mt-0.5 font-semibold">
              <a
                href="https://www.google.com/maps/search/?api=1&query=800+Magnolia+Ave+Piedmont+CA+94611"
                target="_blank"
                rel="noopener noreferrer"
                class="underline underline-offset-4 decoration-pm-ink/30 hover:decoration-pm-red hover:text-pm-red transition-colors"
              >800 Magnolia Ave<br />Piedmont, CA 94611</a>
            </dd>
          </div>
          <div>
            <dt class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55">Dedicated</dt>
            <dd class="mt-0.5 font-semibold">April 29, 2023</dd>
          </div>
          <div>
            <dt class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55">Hours</dt>
            <dd class="mt-0.5 text-pm-ink/65 italic">During programs &amp; open houses</dd>
          </div>
        </dl>

        <!-- Small Google Maps embed for the Engineering Lab. -->
        <iframe
          src="https://www.google.com/maps?q=800+Magnolia+Ave+Piedmont+CA+94611&output=embed"
          title="Map: 800 Magnolia Ave, Piedmont, CA 94611"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          class="mt-6 w-full h-44 md:h-48 rounded-lg border-2 border-pm-ink/15"
        ></iframe>
      </div>
      <div class="md:col-span-5 md:order-2">
        <PhotoCard
          caption="Inside the Mary G. Ross Engineering Lab — FRC team members at the build benches"
          color="purple"
          tilt="right"
          aspect="landscape"
          src="/img/facilities/engineering-lab.jpg"
          alt="Interior of the Mary G. Ross Engineering Lab at Piedmont High School — high schoolers in purple shirts working at tall plywood benches around an FRC robot frame, with team banners, the Team Social board, and FRC parts visible in the background."
        />
      </div>
    </div>
  </section>

  <!-- Full-bleed white strip for the three stipple portraits. White
       background matches the portraits' own backgrounds so the cards
       blend cleanly into the page. -->
  <section class="bg-white border-y border-pm-ink/10">
    <div class="mx-auto max-w-7xl px-6 py-16 md:py-20">
      <p class="text-center font-display font-bold text-xl md:text-2xl tracking-tight leading-tight text-pm-ink max-w-2xl mx-auto mb-12 md:mb-14">
        The lab's spaces are named for three pioneering women in STEAM.
      </p>
      <ul class="grid grid-cols-1 sm:grid-cols-3 gap-10 md:gap-12">
        <li class="text-center">
          <img
            src={`${base}/img/facilities/lab-portraits/cannon.png`}
            alt="Stipple portrait of Annie Jump Cannon"
            class="w-full max-w-[240px] mx-auto h-auto"
            width="600"
            height="540"
            loading="lazy"
          />
          <p class="mt-2 font-display font-bold text-xl md:text-2xl tracking-tight">Annie Jump Cannon</p>
          <p class="mt-1 font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55">Engineering Patio</p>
          <p class="mt-3 text-sm text-pm-ink/75 leading-relaxed max-w-[26ch] mx-auto">
            Astronomer who developed the modern stellar classification system while cataloguing over 350,000 stars.
          </p>
          <p class="mt-2 font-display text-xs tracking-tight text-pm-ink/55">1863–1941</p>
        </li>
        <li class="text-center">
          <img
            src={`${base}/img/facilities/lab-portraits/montague.png`}
            alt="Stipple portrait of Raye Montague"
            class="w-full max-w-[240px] mx-auto h-auto"
            width="600"
            height="540"
            loading="lazy"
          />
          <p class="mt-2 font-display font-bold text-xl md:text-2xl tracking-tight">Raye Montague</p>
          <p class="mt-1 font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55">Computer Lab · ST-127</p>
          <p class="mt-3 text-sm text-pm-ink/75 leading-relaxed max-w-[26ch] mx-auto">
            Naval engineer, computer programmer, and the first computer-aided ship designer.
          </p>
          <p class="mt-2 font-display text-xs tracking-tight text-pm-ink/55">1935–2018</p>
        </li>
        <li class="text-center">
          <img
            src={`${base}/img/facilities/lab-portraits/ross.png`}
            alt="Stipple portrait of Mary G. Ross"
            class="w-full max-w-[240px] mx-auto h-auto"
            width="600"
            height="540"
            loading="lazy"
          />
          <p class="mt-2 font-display font-bold text-xl md:text-2xl tracking-tight">Mary G. Ross</p>
          <p class="mt-1 font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55">Engineering Lab · ST-128</p>
          <p class="mt-3 text-sm text-pm-ink/75 leading-relaxed max-w-[26ch] mx-auto">
            Aerospace engineer whose Skunk Works efforts shaped the U.S. space program.
          </p>
          <p class="mt-2 font-display text-xs tracking-tight text-pm-ink/55">1908–2008</p>
        </li>
      </ul>
    </div>
  </section>

  <!-- Donor list — sibling of the Engineering Lab content section -->
  <section class="mx-auto max-w-7xl px-6 py-16">
    <div class="bg-pm-cream-2/60 border-l-4 border-pm-purple p-6 md:p-8">
      <p class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55">Donors</p>
      <p class="mt-2 text-sm text-pm-ink/75 leading-relaxed max-w-2xl">
        The Engineering Lab exists because of these families, companies, and foundations. Listed in the order they appear on the donor wall inside the lab itself.
      </p>

      <p class="mt-6 font-display text-[0.7rem] uppercase tracking-[0.18em] text-pm-ink/55">Major donors</p>
      <ul class="mt-2 columns-2 sm:columns-3 md:columns-4 gap-x-4 text-xs text-pm-ink/85 [&>li]:break-inside-avoid [&>li]:py-0.5">
        {labMajorDonors.map((d) => <li>{d}</li>)}
      </ul>

      <details class="group mt-6">
        <summary class="cursor-pointer list-none inline-flex items-center gap-2 font-display font-semibold text-sm text-pm-ink hover:text-pm-red transition-colors">
          <span class="group-open:hidden">See all {additionalCount}+ additional donors →</span>
          <span class="hidden group-open:inline">Hide additional donors ↑</span>
        </summary>
        <div class="mt-4">
          <p class="font-display text-[0.7rem] uppercase tracking-[0.18em] text-pm-ink/55">Donors</p>
          <ul class="mt-2 columns-2 sm:columns-3 md:columns-4 gap-x-4 text-xs text-pm-ink/85 [&>li]:break-inside-avoid [&>li]:py-0.5">
            {labDonors.map((d) => <li>{d}</li>)}
          </ul>
        </div>
      </details>
    </div>
  </section>

  <!-- Visiting CTA -->
  <section class="mx-auto max-w-7xl px-6 py-12 pb-20">
    <div class="rounded-3xl bg-pm-ink text-pm-cream p-10 md:p-14 grid md:grid-cols-2 gap-8 items-center">
      <div>
        <Ribbon color="red">Visiting?</Ribbon>
        <h2 class="mt-6 font-display font-bold text-3xl md:text-4xl tracking-tight">
          We love when parents drop in.
        </h2>
        <p class="mt-4 text-pm-cream/85 leading-relaxed">
          Both spaces are most active during practice and build season. To make sure someone&apos;s around when you visit, email ahead, or watch the <a href={link("/events")} class="font-display font-semibold underline underline-offset-4 decoration-pm-red hover:text-pm-red">events calendar</a> for open-house and tournament dates.
        </p>
      </div>
      <div class="md:text-right">
        <a href="mailto:hello@piedmontmakers.org" class="ribbon bg-pm-cream text-pm-ink text-base hover:bg-white transition-colors">
          hello@piedmontmakers.org →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
