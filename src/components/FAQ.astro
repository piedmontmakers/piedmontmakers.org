---
interface Item {
  q: string;
  a: string;
}

interface Props {
  items: Item[];
  class?: string;
}

const { items, class: extra = "" } = Astro.props;
---

<div class:list={["divide-y divide-pm-ink/10 border-y-2 border-pm-ink", extra]}>
  {items.map((item) => (
    <details class="group py-5 px-2 md:px-4">
      <summary class="cursor-pointer list-none flex items-start gap-4">
        <span class="flex-1 font-display font-semibold text-lg md:text-xl tracking-tight text-pm-ink group-hover:text-pm-red transition-colors">
          {item.q}
        </span>
        <span class="font-display font-bold text-2xl text-pm-red shrink-0 leading-none mt-0.5">
          <span class="group-open:hidden">+</span>
          <span class="hidden group-open:inline">−</span>
        </span>
      </summary>
      <div class="mt-3 pr-10 text-pm-ink/80 leading-relaxed font-body" set:html={item.a} />
    </details>
  ))}
</div>
