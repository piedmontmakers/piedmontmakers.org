---
import BaseLayout from "../layouts/BaseLayout.astro";
import Ribbon from "./Ribbon.astro";

interface Props {
  title: string;
  eyebrow: string;
  headline: string;
  blurb: string;
  color?: "red" | "cyan" | "purple" | "ink";
}

const { title, eyebrow, headline, blurb, color = "red" } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (path: string) => `${base}${path}`;
---

<BaseLayout title={`${title} — Piedmont Makers`} description={blurb}>
  <section class="mx-auto max-w-5xl px-6 py-20 md:py-28">
    <Ribbon color={color}>{eyebrow}</Ribbon>
    <h1 class="mt-6 font-display font-bold text-pm-ink text-5xl md:text-6xl tracking-tight leading-[0.98]">
      {headline}
    </h1>
    <p class="mt-6 max-w-2xl text-lg md:text-xl text-pm-ink/75 leading-relaxed">
      {blurb}
    </p>
    <div class="mt-10 inline-flex items-center gap-4 rounded-2xl border-[3px] border-pm-ink bg-pm-cream-2 p-6 md:p-8">
      <span class="font-marker text-2xl text-pm-purple shrink-0">heads up —</span>
      <p class="font-body text-pm-ink/85 leading-relaxed">
        This page is being rebuilt. In the meantime, the <a href={link("/")} class="font-display font-semibold underline underline-offset-4 decoration-pm-red hover:text-pm-red">home page</a> covers most of what you need, or <a href="#newsletter" class="font-display font-semibold underline underline-offset-4 decoration-pm-red hover:text-pm-red">subscribe to the newsletter</a> and we&apos;ll let you know when the full page lands.
      </p>
    </div>
    <div class="mt-12 flex flex-wrap gap-3">
      <a href={link("/")} class="inline-flex items-center gap-2 font-display font-semibold text-pm-ink hover:text-pm-red underline-offset-4 hover:underline">
        ← Back to home
      </a>
    </div>
  </section>
  <slot />
</BaseLayout>
