---
type Color = "red" | "cyan" | "purple" | "ink" | "cream";

interface Props {
  /** Caption text shown below the photo. */
  caption: string;
  /** Background color for the photo placeholder (until real images land). */
  color?: Color;
  /** Slight rotation: "left" tilts CCW, "right" tilts CW, "none" is flat. */
  tilt?: "left" | "right" | "none";
  /** "Tape" decoration at one of the top corners. */
  tape?: "left" | "right" | "none";
  /** Photo aspect ratio: portrait, landscape, square. */
  aspect?: "portrait" | "landscape" | "square";
  /** Optional eyebrow label at the top of the caption (e.g. "FRC Team 8627"). */
  eyebrow?: string;
  /** When supplied, the photo placeholder is replaced with this image. */
  src?: string;
  alt?: string;
  class?: string;
}

const {
  caption,
  color = "cyan",
  tilt = "none",
  tape = "none",
  aspect = "landscape",
  eyebrow,
  src,
  alt = "",
  class: extra = "",
} = Astro.props;

// Allow callers to pass either a relative path like "/img/..." or an external
// URL. Relative paths get the site base prefixed automatically.
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const resolvedSrc = src
  ? (/^(https?:)?\/\//.test(src) ? src : `${base}${src.startsWith("/") ? src : `/${src}`}`)
  : null;

const colorClass = {
  red: "bg-pm-red",
  cyan: "bg-pm-cyan",
  purple: "bg-pm-purple",
  ink: "bg-pm-ink",
  cream: "bg-pm-cream-2",
}[color];

const tiltClass = {
  left: "tilt-left",
  right: "tilt-right",
  none: "",
}[tilt];

const tapeClass = {
  left: "tape-top-left",
  right: "tape-top-right",
  none: "",
}[tape];

const aspectClass = {
  portrait: "aspect-[3/4]",
  landscape: "aspect-[4/3]",
  square: "aspect-square",
}[aspect];
---

<figure class:list={["relative", tiltClass, tapeClass, extra]}>
  <div class:list={["overflow-hidden rounded-2xl shadow-[var(--shadow-card)]", aspectClass, !resolvedSrc ? colorClass : ""]}>
    {resolvedSrc ? (
      <img src={resolvedSrc} alt={alt} class="w-full h-full object-cover" loading="lazy" />
    ) : (
      <div class="w-full h-full flex items-end p-5">
        <span class="font-display text-xs uppercase tracking-[0.18em] text-white/80">
          Photo placeholder
        </span>
      </div>
    )}
  </div>
  <figcaption class="mt-2 px-1">
    {eyebrow && (
      <span class="font-display text-xs uppercase tracking-[0.18em] text-pm-ink/55">{eyebrow}</span>
    )}
    <p class:list={["font-body italic text-sm text-pm-ink/55 leading-snug min-h-[2.6rem]", eyebrow ? "mt-0.5" : ""]}>{caption}</p>
  </figcaption>
</figure>
