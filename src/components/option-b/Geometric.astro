---
type Shape = "circle" | "half-circle-top" | "half-circle-bottom" | "plus" | "triangle" | "square-grid" | "dots" | "rings";

interface Props {
  shape: Shape;
  color?: "red" | "cyan" | "purple" | "ink" | "cream";
  class?: string;
}

const { shape, color = "red", class: extra = "" } = Astro.props;

const fill = {
  red: "#E51926",
  cyan: "#00AEEF",
  purple: "#92278F",
  ink: "#0F1B2D",
  cream: "#FFF6E8",
}[color];
---

{shape === "circle" && (
  <svg viewBox="0 0 100 100" class:list={["block", extra]} aria-hidden="true">
    <circle cx="50" cy="50" r="48" fill={fill} />
  </svg>
)}

{shape === "half-circle-top" && (
  <svg viewBox="0 0 100 50" class:list={["block", extra]} aria-hidden="true">
    <path d="M0 50 A 50 50 0 0 1 100 50 Z" fill={fill} />
  </svg>
)}

{shape === "half-circle-bottom" && (
  <svg viewBox="0 0 100 50" class:list={["block", extra]} aria-hidden="true">
    <path d="M0 0 A 50 50 0 0 0 100 0 Z" fill={fill} />
  </svg>
)}

{shape === "plus" && (
  <svg viewBox="0 0 100 100" class:list={["block", extra]} aria-hidden="true">
    <rect x="40" y="6" width="20" height="88" fill={fill} />
    <rect x="6" y="40" width="88" height="20" fill={fill} />
  </svg>
)}

{shape === "triangle" && (
  <svg viewBox="0 0 100 100" class:list={["block", extra]} aria-hidden="true">
    <polygon points="50,4 96,92 4,92" fill={fill} />
  </svg>
)}

{shape === "square-grid" && (
  <svg viewBox="0 0 100 100" class:list={["block", extra]} aria-hidden="true">
    <g fill={fill}>
      <rect x="0" y="0" width="28" height="28" />
      <rect x="36" y="0" width="28" height="28" />
      <rect x="72" y="0" width="28" height="28" />
      <rect x="0" y="36" width="28" height="28" />
      <rect x="36" y="36" width="28" height="28" />
      <rect x="72" y="36" width="28" height="28" />
      <rect x="0" y="72" width="28" height="28" />
      <rect x="36" y="72" width="28" height="28" />
      <rect x="72" y="72" width="28" height="28" />
    </g>
  </svg>
)}

{shape === "dots" && (
  <svg viewBox="0 0 100 100" class:list={["block", extra]} aria-hidden="true">
    <g fill={fill}>
      {[10, 30, 50, 70, 90].map((y) =>
        [10, 30, 50, 70, 90].map((x) => <circle cx={x} cy={y} r="4" />)
      )}
    </g>
  </svg>
)}

{shape === "rings" && (
  <svg viewBox="0 0 100 100" class:list={["block", extra]} aria-hidden="true">
    <g fill="none" stroke={fill} stroke-width="6">
      <circle cx="50" cy="50" r="46" />
      <circle cx="50" cy="50" r="30" />
      <circle cx="50" cy="50" r="14" />
    </g>
  </svg>
)}
