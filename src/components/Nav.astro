---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (path: string) => `${base}${path}`;

const navItems = [
  { href: "/about", label: "About" },
  { href: "/robotics", label: "Robotics" },
  { href: "/programs", label: "Programs" },
  { href: "/facilities", label: "Facilities" },
  { href: "/events", label: "Events" },
  { href: "/grants", label: "Grants" },
  { href: "/blog", label: "Blog" },
];
---

<header class="sticky top-0 z-50 border-b border-pm-ink/10 bg-pm-paper/85 backdrop-blur-sm">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-6 py-4">
    <a href={link("/")} class="flex items-center gap-3 group">
      <img
        src={`${base}/img/brand/logo.png`}
        alt="Piedmont Makers"
        class="h-14 md:h-16 w-auto transition-transform group-hover:-rotate-1"
        width="360"
        height="89"
      />
    </a>
    <nav class="hidden md:flex items-center gap-7 font-display text-sm font-medium tracking-tight text-pm-ink/80">
      {navItems.map((item) => (
        <a href={link(item.href)} class="hover:text-pm-red transition-colors">{item.label}</a>
      ))}
      <a
        href="https://donate.piedmontmakers.org"
        class="ribbon bg-pm-red text-white text-sm font-semibold tracking-tight shadow-sm hover:bg-pm-red-deep transition-colors"
      >
        Donate
      </a>
    </nav>
    <button
      type="button"
      class="md:hidden inline-flex items-center justify-center rounded-md p-2 text-pm-ink hover:bg-pm-cream-2"
      aria-label="Open menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>
  </div>
</header>
