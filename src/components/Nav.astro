---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (path: string) => `${base}${path}`;

type NavChild = { href: string; label: string };
type NavItem = { href: string; label: string; children?: NavChild[] };

const navItems: NavItem[] = [
  { href: "/about-us", label: "About Us" },
  {
    href: "/robotics",
    label: "Robotics",
    children: [
      { href: "/robotics#fll-explore", label: "FIRST LEGO League Explore" },
      { href: "/robotics#fll-challenge", label: "FIRST LEGO League Challenge" },
      { href: "/robotics#ftc", label: "FIRST Tech Challenge" },
      { href: "/robotics#frc", label: "FIRST Robotics Competition" },
    ],
  },
  {
    href: "/events",
    label: "Events",
    children: [
      { href: "/events/maker-faire", label: "School Maker Faire" },
      { href: "/events/popup-maker-spaces", label: "Popup Maker Spaces" },
      { href: "/events/build-like-a-girl", label: "Build Like a Girl" },
      { href: "/events/fourth-of-july-parade", label: "4th of July Parade" },
      // After-School Enrichment paused for Fall 2026; restore this entry if it
      // comes back in winter 2026-27 or a later session.
      // { href: "/events/after-school", label: "After-School Enrichment" },
    ],
  },
  {
    href: "/facilities",
    label: "Facilities",
    children: [
      { href: "/facilities#tenth-street", label: "10th Street" },
      { href: "/facilities#engineering-lab", label: "Mary G. Ross Engineering Lab" },
    ],
  },
  { href: "/calendar", label: "Calendar" },
  { href: "/teacher-grants", label: "Teacher Grants" },
  { href: "/blog", label: "Blog" },
];
---

<header class="sticky top-0 z-50 border-b border-pm-ink/10 bg-pm-paper/85 backdrop-blur-sm" data-site-nav>
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-6 py-4">
    <a href={link("/")} class="flex items-center gap-3 group">
      <img
        src={`${base}/img/brand/logo.png`}
        alt="Piedmont Makers"
        class="h-14 md:h-16 w-auto transition-transform group-hover:-rotate-1"
        width="360"
        height="89"
      />
    </a>

    <!-- DESKTOP NAV — flyouts on hover/focus -->
    <nav class="hidden md:flex items-center gap-6 font-display text-sm font-medium tracking-tight text-pm-ink/80">
      {navItems.map((item) => (
        item.children ? (
          <div class="relative group">
            <a
              href={link(item.href)}
              class="inline-flex items-center gap-1 py-2 hover:text-pm-red transition-colors"
              aria-haspopup="true"
            >
              {item.label}
              <svg class="w-3 h-3 opacity-60 group-hover:opacity-100 transition-opacity" viewBox="0 0 12 8" fill="none" aria-hidden="true">
                <path d="M1 1.5 L6 6.5 L11 1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
            <div
              class="invisible opacity-0 translate-y-1 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 group-focus-within:visible group-focus-within:opacity-100 group-focus-within:translate-y-0 absolute right-0 top-full pt-2 transition-all duration-150 ease-out"
            >
              <div class="min-w-[16rem] bg-pm-paper border-[3px] border-pm-ink shadow-[var(--shadow-card)]">
                <ul class="py-1">
                  {item.children.map((c) => (
                    <li>
                      <a
                        href={link(c.href)}
                        class="block px-5 py-2 text-sm text-pm-ink/80 hover:bg-pm-cream-2 hover:text-pm-ink transition-colors"
                      >
                        {c.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ) : (
          <a href={link(item.href)} class="py-2 hover:text-pm-red transition-colors">{item.label}</a>
        )
      ))}
      <a
        href="https://donate.piedmontmakers.org"
        data-nav-donate="desktop"
        class="ribbon bg-pm-red text-white text-sm font-semibold tracking-tight shadow-sm hover:bg-pm-red-deep transition-colors"
      >
        Donate
      </a>
    </nav>

    <!-- MOBILE TOGGLE — script below wires it up -->
    <button
      type="button"
      class="md:hidden inline-flex items-center justify-center rounded-md p-2 text-pm-ink hover:bg-pm-cream-2"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-nav-panel"
      data-mobile-nav-toggle
    >
      <svg data-mobile-nav-icon-open xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
      <svg data-mobile-nav-icon-close xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 hidden">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 L18 6 M6 6 L18 18" />
      </svg>
    </button>
  </div>

  <!-- MOBILE PANEL — toggled by the hamburger -->
  <div
    id="mobile-nav-panel"
    data-mobile-nav-panel
    class="md:hidden hidden border-t border-pm-ink/10 bg-pm-paper"
  >
    <nav class="mx-auto max-w-7xl px-6 py-6 font-display">
      <ul class="space-y-1">
        {navItems.map((item) => (
          <li>
            <a
              href={link(item.href)}
              class="block py-2 text-lg font-semibold text-pm-ink hover:text-pm-red transition-colors"
            >
              {item.label}
            </a>
            {item.children && (
              <ul class="mt-1 mb-3 pl-4 border-l-2 border-pm-ink/15 space-y-1">
                {item.children.map((c) => (
                  <li>
                    <a
                      href={link(c.href)}
                      class="block py-1.5 text-sm text-pm-ink/75 hover:text-pm-red transition-colors"
                    >
                      {c.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
        <li class="pt-4">
          <a
            href="https://donate.piedmontmakers.org"
            data-nav-donate="mobile"
            class="ribbon bg-pm-red text-white text-base font-semibold inline-block"
          >
            Donate
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script is:inline>
  // Mobile hamburger toggle. Stays inline so it runs immediately on page
  // load with no framework dependency.
  (function () {
    const toggle = document.querySelector("[data-mobile-nav-toggle]");
    const panel = document.querySelector("[data-mobile-nav-panel]");
    const iconOpen = document.querySelector("[data-mobile-nav-icon-open]");
    const iconClose = document.querySelector("[data-mobile-nav-icon-close]");
    if (!toggle || !panel || !iconOpen || !iconClose) return;

    function setOpen(open) {
      panel.classList.toggle("hidden", !open);
      iconOpen.classList.toggle("hidden", open);
      iconClose.classList.toggle("hidden", !open);
      toggle.setAttribute("aria-expanded", open ? "true" : "false");
      toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
    }

    toggle.addEventListener("click", function () {
      const isOpen = !panel.classList.contains("hidden");
      setOpen(!isOpen);
    });

    // Close on Escape, on link click (so navigation feels immediate), and
    // when the viewport grows past mobile width.
    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape") setOpen(false);
    });
    panel.addEventListener("click", function (e) {
      if (e.target instanceof HTMLAnchorElement) setOpen(false);
    });
    window.addEventListener("resize", function () {
      if (window.innerWidth >= 768) setOpen(false);
    });

    // PostHog: capture clicks on either nav donate button, tagged with
    // surface (desktop or mobile) so we can compare in the dashboard.
    document.querySelectorAll("[data-nav-donate]").forEach(function (el) {
      el.addEventListener("click", function () {
        window.posthog?.capture("donate_nav_clicked", {
          source: el.getAttribute("data-nav-donate"),
        });
      });
    });
  })();
</script>
