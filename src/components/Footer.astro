---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (path: string) => `${base}${path}`;
---

<footer class="mt-32 bg-pm-ink text-pm-cream relative overflow-hidden">
  <!-- Brand watermark — full brand name centered along the bottom of the
       footer, gradient-fading into the navy. Sized in vw so it scales
       fluidly from mobile to desktop while always fitting on one line. -->
  <div aria-hidden="true" class="pointer-events-none select-none absolute inset-x-0 -bottom-2 md:-bottom-4 z-0">
    <p class="text-center whitespace-nowrap font-display font-bold leading-[0.85] text-[11vw] tracking-tight bg-gradient-to-b from-pm-cream/[0.08] via-pm-cream/[0.05] to-pm-cream/0 bg-clip-text text-transparent">
      piedmont makers
    </p>
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 py-16 grid gap-12 md:grid-cols-12">
    <div class="md:col-span-5">
      <p class="font-display text-3xl font-bold tracking-tight">Piedmont Makers</p>
      <p class="mt-3 max-w-sm font-serif text-pm-cream/80 leading-relaxed">
        A 501(&zwnj;c)(3) nonprofit supporting STEAM education and maker culture for kids and adults across the East Bay.
      </p>
    </div>
    <div class="md:col-span-3">
      <p class="font-display text-xs uppercase tracking-[0.18em] text-pm-cream/60">Get involved</p>
      <ul class="mt-3 space-y-2 font-display text-base">
        <li><a href="https://donate.piedmontmakers.org" class="hover:text-pm-red transition-colors">Donate</a></li>
        <li><a href="https://www.bonfire.com/piedmont-makers-t-shirt/" class="hover:text-pm-red transition-colors">Shop t-shirts</a></li>
        <li><a href={link("/about-us")} class="hover:text-pm-red transition-colors">Contact the board</a></li>
        <li><a href={link("/calendar")} class="hover:text-pm-red transition-colors">Volunteer</a></li>
      </ul>
    </div>
    <div class="md:col-span-4">
      <p class="font-display text-xs uppercase tracking-[0.18em] text-pm-cream/60">Follow along</p>
      <ul class="mt-4 flex flex-wrap items-center gap-5">
        <li>
          <a
            href="https://www.instagram.com/piedmontmakers/"
            aria-label="Piedmont Makers on Instagram"
            class="block text-pm-cream/80 hover:text-pm-red transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
        </li>
        <li>
          <a
            href="https://www.linkedin.com/company/piedmont-makers"
            aria-label="Piedmont Makers on LinkedIn"
            class="block text-pm-cream/80 hover:text-pm-red transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </li>
        <li>
          <a
            href="https://www.youtube.com/channel/UCwhVj67myzJX6X7ZxCxai6g"
            aria-label="Piedmont Makers on YouTube"
            class="block text-pm-cream/80 hover:text-pm-red transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6" aria-hidden="true">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        </li>
        <li>
          <a
            href="https://x.com/piedmontmakers"
            aria-label="Piedmont Makers on X"
            class="block text-pm-cream/80 hover:text-pm-red transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        </li>
        <li>
          <a
            href="https://www.facebook.com/groups/piedmontmakers"
            aria-label="Piedmont Makers Facebook group"
            class="block text-pm-cream/80 hover:text-pm-red transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        </li>
      </ul>
    </div>
  </div>
  <div class="relative z-10 border-t border-pm-cream/15">
    <div class="mx-auto max-w-7xl px-6 py-5 font-display text-xs tracking-tight text-pm-cream/60">
      &copy; {new Date().getFullYear()} Piedmont Makers &nbsp;·&nbsp; Vibe coded with 🤖 and ❤️ in Piedmont, CA
    </div>
  </div>

  <!-- Spacer so the brand watermark has room below the copyright row.
       Height tracks the watermark font-size (~11vw) so the bottom of
       the gradient lands near the footer's bottom edge at all widths. -->
  <div class="relative z-0 h-[9vw] min-h-[60px]"></div>
</footer>
