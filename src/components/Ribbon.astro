---
type Color = "red" | "cyan" | "purple" | "ink" | "cream";
type Size = "default" | "display";

interface Props {
  color?: Color;
  size?: Size;
  /** When true, the ribbon "tail" appears on the left side instead of the right. */
  flip?: boolean;
  /** Optional class merge for layout positioning. */
  class?: string;
}

const { color = "red", size = "default", flip = false, class: extra = "" } = Astro.props;

// Cyan and cream ribbons carry ink text: white on the brand cyan is only
// 2.5:1 contrast, well short of WCAG AA. The other backgrounds pass with
// the default white from global.css.
const colorClass = {
  red: "bg-pm-red",
  cyan: "bg-pm-cyan text-pm-ink",
  purple: "bg-pm-purple",
  ink: "bg-pm-ink",
  cream: "bg-pm-cream text-pm-ink",
}[color];

const classes = [
  flip ? "ribbon ribbon-left" : "ribbon",
  size === "display" ? "ribbon-display" : "",
  colorClass,
  extra,
]
  .filter(Boolean)
  .join(" ");
---

<span class={classes}><slot /></span>
